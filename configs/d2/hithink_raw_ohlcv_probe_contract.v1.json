    "raw_high": ["raw_high", "high", "high_price"],
    "raw_low": ["raw_low", "low", "low_price"],
    "raw_close": ["raw_close", "close", "close_price"],
    "volume": ["volume", "vol"],
    "amount": ["amount", "turnover_amount", "turnover"]
  },
  "candidate_optional_fields": [
    "trading_status",
    "price_limit_status",
    "is_suspended",
    "is_st",
    "limit_up_price",
    "limit_down_price",
    "previous_close",
    "turnover",
    "float_shares",
    "source_update_time",
    "observed_at",
    "revision_time"
  ],
  "adjustment_event_expected_semantic_fields": [
    "security_code_or_thscode",
    "event_date",
    "ex_date",
    "record_date",
    "announcement_date",
    "cash_dividend",
    "share_bonus",
    "share_transfer",
    "rights_issue",
    "rights_price",
    "adjustment_factor",
    "factor_as_of_time",
    "adjustment_revision"
  ],
  "adjustment_event_field_aliases": {
    "security_code_or_thscode": ["security_code", "thscode", "ts_code", "code"],
    "event_date": ["event_date", "ex_date_ms"],
    "ex_date": ["ex_date", "exright_date", "ex_date_ms"],
    "record_date": ["record_date"],
    "announcement_date": ["announcement_date", "ann_date"],
    "cash_dividend": ["cash_dividend", "dividend_per_share"],
    "share_bonus": ["share_bonus", "per_share_bonus"],
    "share_transfer": ["share_transfer"],
    "rights_issue": ["rights_issue", "allotment_ratio"],
    "rights_price": ["rights_price", "allotment_price"],
    "adjustment_factor": ["adjustment_factor", "factor"],
    "factor_as_of_time": ["factor_as_of_time"],
    "adjustment_revision": ["adjustment_revision"]
  },
  "unit_inference_policy": {
    "amount_unit_candidates": ["yuan", "thousand_yuan", "ten_thousand_yuan", "unknown"],
    "volume_unit_candidates": ["share", "lot", "unknown"],
    "missing_or_ambiguous_unit_status": "warning"
  },
  "probe_output_sections": [
    "raw_k_schema_report",
    "adjustment_event_schema_report",
    "coverage_report",
    "unit_inference_report",
    "time_semantics_report",
    "missing_field_report",
    "fallback_readiness_report",
    "a_stock_data_removal_report",
    "probe_diagnostics"
  ],
  "probe_statuses": [
