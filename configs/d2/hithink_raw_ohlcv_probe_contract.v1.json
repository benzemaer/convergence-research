  "stage_1_release_decisions": {
    "formal_source_acceptance_decision": "formal_source_acceptance_blocked_pending_probe_review",
    "raw_materialization_decision": "raw_materialization_not_authorized_in_stage_1",
    "d3_generation_decision": "d3_generation_blocked",
