  "unknown_policy": {
    "missing_not_false": true,
    "unknown_not_normal": true,
    "suspension_no_repeat_close_fill": true,
    "missing_previous_close_no_same_day_open_or_zero_gap": true,
    "nonpositive_price_log_indicators_unknown": true,
    "factor_asof_revision_missing_blocks_formal": true,
    "corporate_action_evidence_missing_mechanical_gap_unknown": true,
    "amount_volume_unit_unknown_no_full_ready": true,
    "price_limit_status_missing_diagnostic_required": true
  },
  "trading_constraint_policy": {
    "controlled_vocabulary": ["normal_trading", "suspended", "zero_volume", "limit_up", "limit_down", "one_price_limit_up", "one_price_limit_down", "reopen_after_suspension", "unknown"],
    "unknown_not_normal": true,
    "suspended_not_valid_window_observation": true,
    "zero_volume_not_ordinary_low_participation": true,
    "limit_rows_retained_with_r1_diagnostic": true,
    "missing_constraints_downgrade_readiness": "diagnostic_required"
  },
  "mechanical_gap_policy": {
    "controlled_vocabulary": ["none", "market_gap", "corporate_action_mechanical_gap", "suspension_reopen_gap", "limit_constraint_gap", "code_mapping_gap", "unknown"],
    "corporate_action_mechanical_gap_not_market_gap": true,
    "missing_corporate_action_evidence_gap_unknown": true,
    "unknown_gap_not_none": true,
    "no_future_return_or_direction_for_gap": true
  },
  "amount_volume_policy": {
    "amount_unit_vocabulary": ["yuan", "thousand_yuan", "ten_thousand_yuan", "unknown"],
    "volume_unit_vocabulary": ["share", "lot", "unknown"],
    "unknown_unit_readiness": "unit_validation_required",
    "amount_volume_no_cross_unit_mix": true
  },
  "vwap_policy": {
    "daily_vwap_formula": "amount_yuan / volume_shares",
    "daily_vwap_must_be_within_raw_low_high_after_unit_normalization": true,
    "unit_range_mismatch_flag": "amount_volume_unit_mismatch"
  },
  "continuous_price_policy": {
    "qfq_hfq_not_raw_trading_fact": true,
    "implied_factor_not_vendor_official_factor": true,
    "factor_missing_continuous_exploration_only_or_unknown": true,
    "factor_as_of_time_missing_blocks_formal_d2": true
  },
  "d3_handoff_requirements": {
    "d3_generation_authorized_by_this_pr": false,
    "requires_quality_flags": true,
    "requires_trading_constraint_flags": true,
    "requires_mechanical_gap_attribution": true,
    "requires_pcvt_input_readiness": true
