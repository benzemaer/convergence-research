    "execution_price",
    "vendor_payload",
    "raw_vendor_payload",
    "raw_rows",
    "qfq_rows",
    "hfq_rows"
  ],
  "forbidden_path_policy": {
    "reject_payload_path_before_open": true,
    "reject_payload_content_paths": true,
    "duckdb_connection_authorized": false,
    "external_api_call_authorized": false,
    "manifest_write_authorized": false,
    "data_version_write_authorized": false,
    "repository_data_artifact_write_authorized": false,
    "forbidden_patterns": [
      "data/raw",
      "data\\raw",
      "data/external",
      "data\\external",
      "MarketDB",
      "marketdb",
      ".duckdb",
      ".day",
      "vendor_payload",
      "raw_rows",
      "qfq_rows",
      "hfq_rows"
    ]
  },
  "depends_on": [
    "D3_DAILY_MARKET_OBSERVATIONS_CONTRACT_V1",
    "D3_DAILY_MARKET_OBSERVATION_VALUES_CONTRACT_V1",
    "D3_COMPONENT_LINEAGE_NO_BYPASS_CONTRACT_V1",
    "D3_QUALITY_READINESS_CONTRACT_V1",
    "D3_SYNTHETIC_DAILY_OBSERVATION_BUILD_CONTRACT_V1",
    "D2_ACCEPTANCE_D3_HANDOFF_CONTRACT_V1",
    "D2_MARKET_QUALITY_PCVT_DEPENDENCY_CONTRACT_V1",
    "D0_DATA_PRODUCT_CONTRACTS_V1"
  ]
}
