{
  "$schema": "../../schemas/d3_t10_field_availability_probe_gap_fill_contract.schema.json",
  "config_version": "1.0.0",
  "contract_id": "D3_T10_FIELD_AVAILABILITY_PROBE_GAP_FILL_CONTRACT_V1",
  "task_id": "D3-T10",
  "contract_status": "accepted",
  "contract_scope": "d3_field_availability_probe_and_generic_market_field_gap_fill",
  "placement_rationale": "The probed fields are D3 generic market observation fields required by multiple R0 inputs, not R0-specific metric logic.",
  "depends_on": [
    "D3_DAILY_MARKET_OBSERVATION_VALUES_CONTRACT_V1",
    "D3_T07_CANDIDATE_DAILY_OBSERVATION_CONTRACT_V1",
    "D3_T08_RESEARCH_DATASET_REGISTRY_CONTRACT_V1",
    "R0_T01_PCVT_CANDIDATE_SPEC_V1",
    "R0_T02_INPUT_READINESS_GATE_CONTRACT_V1"
  ],
  "formal_data_version_authorized": false,
  "duckdb_write_authorized": false,
  "pcvt_metric_calculation_authorized": false,
  "pcvt_percentile_generation_authorized": false,
  "pcvt_score_generation_authorized": false,
  "pcvt_state_generation_authorized": false,
  "future_label_generation_authorized": false,
  "returns_generation_authorized": false,
  "backtest_generation_authorized": false,
  "portfolio_generation_authorized": false,
  "real_provider_probe_authorized": true,
  "provider_probe_raw_payload_commit_authorized": false,
  "credential_commit_authorized": false,
  "field_probe_matrix_columns": [
    "field_name",
    "required_by",
    "required_for_indicator",
    "current_status",
    "source_table_or_file",
    "unit_status",
    "quality_status",
    "blocking_reason",
    "suggested_fix"
  ],
  "r0_indicator_ids": [
    "P1_NATR14",
    "P2_LogRange20",
    "C1_LogMASpread_5_60",
    "C2_AdjVWAPSpread_5_60",
    "T1_ER20",
    "T2_AbsTrendT20",
    "V1_TurnoverShrink20_60",
    "V2_AmountLevel20Pct"
  ],
  "tnskhdata_probe": {
    "token_env_names": [
      "TNSKHDATA_TOKEN",
      "TUSHARE_TOKEN",
      "TNS_TOKEN"
    ],
    "cookie_allowed": false,
    "raw_payload_output_allowed": false,
    "sample_security_count_min": 3,
    "sample_security_count_max": 5,
    "sample_trading_day_count_min": 3,
    "sample_trading_day_count_max": 5,
    "daily_call": "pro.daily(ts_code=..., start_date=..., end_date=...)",
    "daily_basic_call": "pro.daily_basic(ts_code=..., start_date=..., end_date=...)"
  },
  "standardization_rules": {
    "volume_raw": "daily.vol",
    "volume_unit": "hand",
    "volume_shares_formula": "volume_raw * 100",
    "amount_raw": "daily.amount",
    "amount_unit": "thousand_yuan",
    "amount_yuan_formula": "amount_raw * 1000",
    "daily_vwap_formula": "amount_yuan / volume_shares",
    "total_share_raw": "daily_basic.total_share",
    "total_share_unit": "ten_thousand_shares",
    "total_share_shares_formula": "total_share_raw * 10000",
    "float_share_raw": "daily_basic.float_share",
    "float_share_unit": "ten_thousand_shares",
    "float_share_shares_formula": "float_share_raw * 10000",
    "free_share_raw": "daily_basic.free_share",
    "free_share_unit": "ten_thousand_shares",
    "free_share_shares_formula": "free_share_raw * 10000",
    "turnover_float_formula": "volume_shares / float_share_shares",
    "turnover_free_formula": "volume_shares / free_share_shares",
    "derived_turnover_rate_pct_formula": "turnover_float * 100",
    "derived_turnover_rate_f_pct_formula": "turnover_free * 100"
  },
  "quality_status_fields": [
    "amount_volume_unit_status",
    "daily_vwap_range_status",
    "share_field_status",
    "turnover_field_status",
    "provider_turnover_crosscheck_status"
  ],
  "quality_rules": [
    "volume_shares >= 0",
    "amount_yuan >= 0",
    "daily_vwap between raw_low and raw_high within tolerance",
    "total_share_shares > 0",
    "float_share_shares > 0",
    "free_share_shares > 0",
    "free_share_shares <= float_share_shares",
    "float_share_shares <= total_share_shares",
    "turnover_float >= 0",
    "turnover_free >= 0",
    "zero_volume_flag must not be interpreted as low participation",
    "unit unknown must not be treated as ready"
  ],
  "provider_turnover_crosscheck": {
    "derived_turnover_rate_pct": "turnover_float * 100",
    "derived_turnover_rate_f_pct": "turnover_free * 100",
    "turnover_rate_tolerance_pct": 0.05,
    "turnover_rate_f_tolerance_pct": 0.05
  },
  "generic_d3_fields_to_add": [
    "volume_raw",
    "volume_unit",
    "volume_shares",
    "amount_raw",
    "amount_unit",
    "amount_yuan",
    "daily_vwap",
    "daily_vwap_range_status",
    "zero_volume_flag",
    "zero_amount_flag",
    "total_share_raw",
    "total_share_unit",
    "total_share_shares",
    "float_share_raw",
    "float_share_unit",
    "float_share_shares",
    "free_share_raw",
    "free_share_unit",
    "free_share_shares",
    "turnover_rate",
    "turnover_rate_f",
    "turnover_float",
    "turnover_free",
    "turnover_field_status",
    "share_field_status",
    "provider_turnover_crosscheck_status",
    "total_mv",
    "circ_mv",
    "limit_status"
  ],
  "future_alternative_v_candidates": [
    "TurnoverShrink20_60",
    "FreeTurnoverShrink20_60",
    "TurnoverLevel20Pct",
    "FreeTurnoverLevel20Pct"
  ],
  "d3_t10_did_not_replace_r0_baseline_at_that_time": true,
  "historical_r0_baseline_v_indicators_at_d3_t10": [
    "V1_VolShrink20_60",
    "V2_AmountLevel20Pct"
  ],
  "superseded_by": "R0_T03_V_LAYER_TURNOVER_READINESS_CONTRACT_V1",
  "current_r0_baseline_v_indicators": [
    "V1_TurnoverShrink20_60",
    "V2_AmountLevel20Pct"
  ],
  "prohibited_outputs": [
    "pcvt_values",
    "pcvt_percentiles",
    "pcvt_scores",
    "pcvt_states",
    "state_intervals",
    "future_labels",
    "future_returns",
    "breakout_direction",
    "backtest",
    "portfolio",
    "formal_data_version",
    "raw_provider_payload",
    "cookie",
    "credential"
  ]
}
