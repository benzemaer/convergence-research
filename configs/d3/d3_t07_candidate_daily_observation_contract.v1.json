{
  "$schema": "../../schemas/d3_t07_candidate_daily_observation_contract.schema.json",
  "config_version": "1.0.0",
  "contract_id": "D3_T07_CANDIDATE_DAILY_OBSERVATION_CONTRACT_V1",
  "task_id": "D3-T07",
  "contract_status": "accepted",
  "contract_scope": "candidate_daily_observation_generation_from_d2_t20",
  "source_task_id": "D2-T20",
  "source_candidate": "D2-T20 evidence-verified research candidate",
  "target_table": "d3_candidate_daily_observation",
  "target_duckdb": "d3_t07_candidate_daily_observation.duckdb",
  "d3_candidate_generation_authorized": true,
  "formal_data_version_authorized": false,
  "formal_source_promotion_authorized": false,
  "r0_state_generation_authorized": false,
  "labels_generation_authorized": false,
  "returns_generation_authorized": false,
  "backtest_generation_authorized": false,
  "portfolio_generation_authorized": false,
  "input_gate_required_fields": [
    "d2_acceptance_decision",
    "d3_generation_authorized",
    "policy_based_acceptance",
    "policy_evidence_pending_hash",
    "formal_duckdb_write_authorized",
    "data_version_published",
    "d3_rows_generated",
    "r0_state_generated"
  ],
  "required_source_tables": [
    "staging_daily_raw",
    "d2_source_status",
    "d2_factor_evidence",
    "staging_stk_limit",
    "staging_adj_factor",
    "d2_policy_listing_pause_intervals",
    "d2_policy_adj_factor_overrides",
    "d2_policy_corporate_action_evidence",
    "d2_policy_evidence_documents"
  ],
  "primary_key": ["ts_code", "trade_date"],
  "required_output_fields": [
    "ts_code",
    "trade_date",
    "open",
    "high",
    "low",
    "close",
    "vol",
    "amount",
    "effective_adj_factor",
    "adjusted_open",
    "adjusted_high",
    "adjusted_low",
    "adjusted_close",
    "trading_status",
    "daily_status",
    "price_limit_status",
    "adjustment_factor_status",
    "up_limit",
    "down_limit",
    "is_limit_up",
    "is_limit_down",
    "is_listing_pause",
    "is_policy_adjusted",
    "adj_factor_policy_type",
    "adj_factor_policy_source",
    "policy_evidence_status",
    "policy_evidence_level",
    "source_task_id",
    "d2_source_duckdb",
    "generated_by_task",
    "row_provenance"
  ],
  "effective_adj_factor_rules": [
    "resolved uses staging_adj_factor.adj_factor",
    "neutral_factor_1_policy uses 1.0",
    "factor_interval_policy uses d2_policy_corporate_action_evidence interval",
    "missing or ambiguous factor must block candidate acceptance"
  ],
  "listing_pause_policy": {
    "exclude_listing_pause_rows": true,
    "is_listing_pause_in_output_must_be_false": true,
    "zero_price_fill_authorized": false
  },
  "quality_blockers": [
    "duplicate_observation_key_count",
    "null_ohlc_count",
    "non_positive_price_count",
    "high_low_violation_count",
    "missing_effective_adj_factor_count",
    "factor_interval_unresolved_count"
  ],
  "required_outputs": [
    "d3_t07_candidate_daily_observation.duckdb",
    "d3_t07_generation_summary.json",
    "d3_t07_quality_report.json",
    "d3_t07_handoff_candidate_report.json",
    "d3_t07_row_count_by_security.csv",
    "d3_t07_policy_usage_summary.csv",
    "d3_t07_excluded_listing_pause_rows.csv",
    "d3_t07_unresolved_rows.csv",
    "d3_t07_candidate_file_hash_summary.json"
  ],
  "prohibited_outputs": [
    "data_version.json",
    "formal_manifest.json",
    "labels.csv",
    "returns.csv",
    "backtest.csv",
    "portfolio.csv",
    "r0_state.csv"
  ],
  "next_planned_task": "D3-T08 PCVT input readiness and feature-base quality checks"
}
