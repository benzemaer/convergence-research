      "minimum_window_valid_trading_days": 21,
      "readiness_status_vocabulary": ["ready", "partial", "blocked", "unknown", "diagnostic_required", "not_applicable"],
      "blocking_conditions": ["window_not_full", "nonpositive adjusted close"],
      "formal_readiness": "requires adj_close, valid 21 trading-day window",
      "exploration_readiness": "partial allowed only with explicit blocking reasons"
    },
    {
      "indicator_id": "T2_AbsTrendT20",
