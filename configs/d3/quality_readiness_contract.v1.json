      "blocking_conditions": ["volume unit fail or unknown", "window_not_full", "corporate-action volume comparability policy missing"],
      "formal_readiness": "requires volume, valid 80 trading-day window, volume unit and corporate-action volume comparability policy",
      "exploration_readiness": "partial allowed only with explicit blocking reasons"
    },
    {
      "indicator_id": "V2_AmountLevel20Pct",
      "pcvt_layer": "V",
      "required_value_fields": ["amount"],
      "required_quality_domains": ["amount_volume_unit_validation", "window_validity"],
      "minimum_window_valid_trading_days": 20,
      "readiness_status_vocabulary": ["ready", "partial", "blocked", "unknown", "diagnostic_required", "not_applicable"],
      "blocking_conditions": ["amount unit fail or unknown", "strict-past history missing"],
      "formal_readiness": "requires amount, valid strict-past history, amount unit validation",
      "exploration_readiness": "partial allowed only with explicit blocking reasons"
    }
  ],
  "prohibited_fields": [
