      "required_quality_domains": ["amount_volume_unit_validation", "daily_vwap_range_validation", "raw_ohlcv_integrity", "continuous_ohlc_integrity"],
      "minimum_window_valid_trading_days": 60,
      "readiness_status_vocabulary": ["ready", "partial", "blocked", "unknown", "diagnostic_required", "not_applicable"],
      "blocking_conditions": ["unit validation fail or unknown", "daily_vwap range fail or unknown", "missing adjusted VWAP policy"],
      "formal_readiness": "requires amount, volume, raw_low, raw_high, adj_close, unit validation and adjusted VWAP policy",
      "exploration_readiness": "partial allowed only with explicit blocking reasons"
