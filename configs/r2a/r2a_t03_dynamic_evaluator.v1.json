      "daily_dimension_scores": ["score_release_id:VARCHAR", "security_id:VARCHAR", "trading_date:DATE", "observation_sequence:BIGINT", "dimension_id:VARCHAR", "score_dimension:DOUBLE?", "score_dimension_min:DOUBLE?", "eligible_dimension:BOOLEAN", "validity_status:VARCHAR", "reason_codes:VARCHAR[]", "available_time:TIMESTAMP WITH TIME ZONE"]
