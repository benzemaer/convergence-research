        "raw_snapshot_required": true,
        "sha256_required": true,
        "source_snapshot_id_required": true,
        "immutable_snapshot_required": true
      },
      "manifest_requirements": {
        "dataset_manifest_required": true,
        "source_snapshot_manifest_required": true,
        "run_manifest_required": true,
        "input_hashes_required": true
