{
  "$schema": "../../schemas/d0_data_product_contracts.schema.json",
  "config_version": "1.0.0",
  "task_id": "D0-T03",
  "contract_id": "D0_DATA_PRODUCT_CONTRACTS_V1",
  "contract_status": "accepted",
  "depends_on": [
    "D0-T01",
    "D0-T02",
    "D0_SOURCE_REGISTRY_V1",
    "DR-001"
  ],
  "warehouse_boundary": {
    "duckdb_role": "DuckDB only stores structured registries, normalized facts, reproducible derived layers, and research entry tables.",
    "raw_bytes_rule": "Raw responses, raw files, vendor exports, and collection logs must remain under data/raw or data/external and enter DuckDB only through path, SHA-256, snapshot id, and manifest references.",
    "implementation_exclusions": [
      "no_duckdb_file",
      "no_duckdb_dependency",
      "no_ddl",
      "no_loader",
      "no_external_api_call",
      "no_data_artifact"
    ]
  },
  "global_requirements": {
    "required_in_all_formal_tables": [
      "data_version",
      "universe_id",
      "time_segment_id",
      "source_registry_id",
      "source_snapshot_id",
      "run_id"
    ],
    "traceability_requirements": [
      "input_hashes",
      "dataset_manifest",
      "source_snapshot_manifest",
      "run_manifest"
    ],
    "contract_requirements": [
      "grain",
      "primary_key",
      "required_fields",
      "nullable_policy",
      "quality_checks",
      "as_of_policy",
      "revision_policy"
    ],
    "research_entry_rule": "R0 must use d3.daily_market_observations as the only formal daily entry point and must not read D1/D2 tables directly."
  },
  "tables": [
    {
      "layer": "D1",
      "table_name": "d1.security_master",
      "table_role": "Security identity, listing lifecycle, exchange, and security type master data.",
      "grain": "One security identity row per data_version, universe_id, time_segment_id, and security_id.",
      "primary_key": [
        "data_version",
        "universe_id",
        "time_segment_id",
        "security_id"
      ],
      "required_fields": [
        "data_version",
        "universe_id",
        "time_segment_id",
        "security_id",
        "ticker",
        "exchange",
        "security_name",
        "listing_date",
        "delisting_date",
        "security_type",
        "source_registry_id",
        "source_snapshot_id",
        "run_id"
      ],
      "nullable_fields": [
        "delisting_date"
      ],
      "nullable_policy": "Only fields listed in nullable_fields may be null; unknown source quality must not be silently converted to false.",
      "source_registry_requirements": {
        "allowed_source_registry_ids": [
          "HITHINK_FINANCIAL_API"
        ],
        "prohibited_source_registry_ids": [
          "CSINDEX_OFFICIAL",
          "A_STOCK_DATA_RECON"
        ],
        "formal_ingestion_authorized": false,
        "sole_primary_source_allowed": false,
        "reason": "HiThink is a candidate master-data source, but terms/as-of/revision review remains pending."
      },
      "source_snapshot_requirements": {
        "raw_snapshot_required": true,
        "sha256_required": true,
        "source_snapshot_id_required": true,
        "immutable_snapshot_required": true
      },
      "manifest_requirements": {
        "dataset_manifest_required": true,
        "source_snapshot_manifest_required": true,
        "run_manifest_required": true,
        "input_hashes_required": true
      },
      "as_of_policy": "Identity facts must be observed_at-bounded to the snapshot retrieval time or documented vendor effective time.",
      "revision_policy": "Corrections or vendor restatements require a new source_snapshot_id or data_version; old snapshots remain immutable.",
      "quality_checks": [
        "primary_key_unique",
        "security_id_not_null",
        "ticker_exchange_mapping_unique_within_version",
        "listing_date_not_after_delisting_date",
        "source_registry_allowed"
      ],
      "blocking_conditions": [
        "missing_raw_snapshot",
        "missing_sha256",
        "missing_manifest_reference",
        "source_terms_pending_for_formal_ingestion"
      ],
      "downstream_allowed_uses": [
        "D1_identity_design",
        "D2_join_key_validation"
      ],
      "downstream_prohibited_uses": [
        "R0_direct_input",
        "trade_execution_input"
      ]
    },
