    "worker_count": 1,
    "duckdb_threads": 12,
    "memory_limit": "12GB",
    "random_seed": null,
    "run_id_pattern": "^EXP-A01-[0-9]{8}T[0-9]{6}(?:[0-9]{3,6})?Z$",
