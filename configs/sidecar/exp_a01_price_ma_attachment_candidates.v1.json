          "missing_effective_adj_factor_count",
          "factor_interval_unresolved_count"
        ]
      },
      "expected_price_observation_index": {
        "artifact_id": "expected_price_observation_index",
        "artifact_kind": "duckdb_table",
        "logical_object": "expected_price_observation_index",
        "filename": "expected_price_observation_index.duckdb",
        "table": "expected_price_observation_index",
        "source_contract": "EXP_A01_EXPECTED_PRICE_OBSERVATION_INDEX_V1",
        "source_role": "authorized_dense_expected_observation_index",
        "formal_data_version": false,
        "required_columns": [
          "security_id",
          "trading_date",
          "observation_sequence",
          "expected_observation_status",
          "source_contract",
          "source_ref"
        ]
      }
    }
  },
  "input_governance": {
    "d3_t08_required": false,
    "d3_t08_policy": "not_required_for_EXP-A01",
    "rationale": "D3-T08 adds no A1/A2/A2b calculation field and its relevant checks are duplicated by the D3-T07 gate, direct main-table checks, dense-index reconciliation and independent full recomputation."
  },
  "execution_profile_governance": {
    "owner_override": true,
    "authorization_continuity": "preserved",
    "configuration_review_required": false,
    "implementation_review_required": false,
    "human_rereview_required": false,
    "authorization_roll_forward": "automatic_after_exact_head_quality_success",
    "scientific_contract_unchanged": true
  },
  "d3_t07_evidence_gate": {
    "accepted_generation_decisions": [
      "accepted_candidate_observation",
      "accepted_candidate_observation_with_warnings"
    ],
    "generated_field": "d3_candidate_observation_generated",
    "formal_data_version_field": "formal_data_version_published",
    "forbidden_true_fields": [
      "labels_generated",
      "returns_generated",
      "pcvt_values_generated",
      "r0_state_generated"
    ],
    "quality_blockers": [
      "duplicate_observation_key_count",
      "null_ohlc_count",
      "non_positive_price_count",
      "high_low_violation_count",
      "missing_effective_adj_factor_count",
      "factor_interval_unresolved_count"
    ],
    "main_table_identity": {
      "source_task_id": "D2-T20",
      "generated_by_task": "D3-T07",
      "listing_pause_must_be": false
    }
  },
  "dense_window_contract": {
    "index_source_contract": "EXP_A01_EXPECTED_PRICE_OBSERVATION_INDEX_V1",
    "statuses": ["present", "listing_pause", "missing", "unresolved"],
    "present_requires_exactly_one_main_row": true,
    "non_present_must_not_be_in_main_table": true,
    "civil_date_continuity_substitution_forbidden": true,
    "sequence_gap_is_input_contract_error": true,
    "window_observation_counts": {
      "A1_LogBodyCenterToMACloudCenter_5_60": 60,
      "A2_BodyCenterOutsideMACloudRate20_5_60": 79,
      "A2b_BodyToMACloudGapMean20_5_60": 79
    }
  },
  "output_contract": {
