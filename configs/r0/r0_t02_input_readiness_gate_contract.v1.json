{
  "$schema": "../../schemas/r0/r0_t02_input_readiness_gate_contract.schema.json",
  "config_version": "1.0.0",
  "contract_id": "R0_T02_INPUT_READINESS_GATE_CONTRACT_V1",
  "task_id": "R0-T02",
  "contract_status": "draft",
  "contract_scope": "input_readiness_gate_for_c2_v1_corporate_action_audit",
  "depends_on": [
    "R0_T01_PCVT_CANDIDATE_SPEC_V1",
    "D3_T07_CANDIDATE_DAILY_OBSERVATION_CONTRACT_V1",
    "D3_T08_RESEARCH_DATASET_REGISTRY_CONTRACT_V1",
    "D3_QUALITY_READINESS_CONTRACT_V1",
    "D2_MARKET_QUALITY_PCVT_DEPENDENCY_CONTRACT_V1"
  ],
  "real_data_read_authorized": false,
  "synthetic_test_only": true,
  "duckdb_write_authorized": false,
  "pcvt_metric_calculation_authorized": false,
  "pcvt_percentile_generation_authorized": false,
  "pcvt_score_generation_authorized": false,
  "pcvt_state_generation_authorized": false,
  "future_label_generation_authorized": false,
  "returns_generation_authorized": false,
  "backtest_generation_authorized": false,
  "portfolio_generation_authorized": false,
  "formal_data_version_authorized": false,
  "allowed_logical_input_sources": [
    "d3_candidate_daily_observation",
    "d3_t08_research_dataset_registry",
    "d3_quality_readiness_contract",
    "r0_t01_pcvt_candidate_spec"
  ],
  "prohibited_direct_sources": [
    "d1.raw_market_prices",
    "d2.adjusted_market_prices",
    "d2.market_price_quality_flags",
    "d2.membership_alignment",
    "data/raw",
    "data/external",
    "MarketDB",
    ".day"
  ],
  "readiness_status_vocabulary": [
    "ready",
    "unknown",
    "diagnostic_required",
    "blocked",
    "not_applicable"
  ],
  "reason_code_vocabulary": [
    "ready_no_blocker",
    "missing_required_field",
    "amount_unit_unknown",
    "volume_unit_unknown",
    "amount_volume_unit_status_fail",
    "daily_vwap_range_unknown",
    "daily_vwap_range_fail",
    "adjusted_vwap_policy_missing",
    "corporate_action_window_without_common_basis",
    "volume_comparability_policy_missing",
    "corporate_action_volume_comparability_policy_missing",
    "suspension_in_window",
    "zero_volume_in_window",
    "window_not_full",
    "listing_age_insufficient",
    "d3_lineage_missing",
    "direct_d1_d2_bypass_detected",
    "unknown_not_false_guard"
  ],
  "c2_gate": {
    "indicator_id": "C2_AdjVWAPSpread_5_60",
    "required_fields": [
      "amount",
      "volume",
      "amount_unit",
      "volume_unit",
      "amount_volume_unit_status",
      "raw_low",
      "raw_high",
      "daily_vwap_range_status",
      "corporate_action_flag",
      "adjusted_vwap_policy",
      "trading_status"
    ],
    "required_policy": "adjusted_vwap_policy",
    "rules": [
      "amount_unit unknown prevents ready",
      "volume_unit unknown prevents ready",
      "amount_volume_unit_status fail or unknown prevents ready",
      "daily_vwap_range_status fail or unknown prevents ready",
      "non corporate-action window can be ready when unit and DailyVWAP checks pass",
      "corporate-action window requires adjusted_vwap_policy or common corporate-action basis",
      "raw VWAP across corporate-action window must not be treated as adjusted VWAP",
      "suspension zero volume and abnormal amount or volume are not ordinary usable observations"
    ],
    "raw_vwap_across_corporate_action_window_forbidden_as_adjusted_vwap": true
  },
  "v1_gate": {
    "indicator_id": "V1_VolShrink20_60",
    "required_fields": [
      "volume",
      "volume_unit",
      "trading_status",
      "corporate_action_flag",
      "suspension_flag"
    ],
    "candidate_policy_fields": [
      "adjusted_volume",
      "common_share_basis_policy",
      "volume_comparability_policy"
    ],
    "required_policy_any_of": [
      "volume_comparability_policy",
      "common_share_basis_policy"
    ],
    "observation_window": {
      "recent_trading_days": 20,
      "prior_non_overlapping_trading_days": 60,
      "total_trading_days": 80
    },
    "rules": [
      "80 day window must be complete",
      "volume_unit unknown prevents ready",
      "suspension is not ordinary low participation",
      "zero_volume is not ordinary low participation",
      "raw volume may be ready when no share-comparability corporate action exists and volume_unit is known",
      "share-comparability corporate action window requires adjusted_volume common_share_basis_policy or volume_comparability_policy",
      "missing comparability policy across share-change window produces unknown",
      "corporate-action volume level changes must not be interpreted as participation contraction"
    ]
  },
  "readiness_output_contract": {
    "future_report_object": "r0_t02_input_readiness_gate_report.json",
    "future_summary_objects": [
      "r0_t02_c2_v1_readiness_summary.csv",
      "r0_t02_blocking_reason_summary.csv"
    ],
    "real_output_generation_authorized": false,
    "synthetic_fixture_outputs_only": true
  },
  "prohibited_outputs": [
    "pcvt_values",
    "pcvt_percentiles",
    "pcvt_scores",
    "pcvt_states",
    "state_intervals",
    "future_labels",
    "future_returns",
    "breakout_direction",
    "backtest",
    "portfolio",
    "formal_data_version"
  ]
}
