  "active_raw_metrics": [
    {
      "indicator_id": "P1_NATR14",
      "raw_metric_name": "NATR14",
      "required_observation_count": 15,
      "source_field_names": [
        "adjusted_high",
        "adjusted_low",
        "adjusted_close"
      ],
      "formula": "wilder_atr14_divided_by_current_adjusted_close"
    },
    {
      "indicator_id": "P2_LogRange20",
      "raw_metric_name": "LogRange20",
      "required_observation_count": 20,
      "source_field_names": [
        "adjusted_high",
        "adjusted_low"
      ],
      "formula": "log(max_adjusted_high_20_over_min_adjusted_low_20)"
    },
    {
      "indicator_id": "C1_LogMASpread_5_60",
      "raw_metric_name": "LogMASpread_5_60",
      "required_observation_count": 60,
      "source_field_names": [
        "adjusted_close"
      ],
      "formula": "population_std_of_log_ma_5_10_20_30_60"
    },
    {
      "indicator_id": "C2_AdjVWAPSpread_5_60",
      "raw_metric_name": "AdjVWAPSpread_5_60",
      "required_observation_count": 60,
      "source_field_names": [
        "daily_vwap",
        "volume_shares"
      ],
      "formula": "population_std_of_log_volume_weighted_vwap_5_10_20_30_60",
      "readiness_gate": "R0_T02_INPUT_READINESS_GATE_CONTRACT_V1"
    },
    {
      "indicator_id": "T1_ER20",
      "raw_metric_name": "ER20",
      "required_observation_count": 21,
      "source_field_names": [
        "adjusted_close"
      ],
      "formula": "absolute_20_day_log_change_over_sum_absolute_daily_log_changes"
    },
    {
      "indicator_id": "T2_AbsTrendT20",
      "raw_metric_name": "AbsTrendT20",
      "required_observation_count": 20,
      "source_field_names": [
        "adjusted_close"
      ],
      "formula": "absolute_ols_log_close_slope_t_statistic"
    },
    {
      "indicator_id": "V1_TurnoverShrink20_60",
      "raw_metric_name": "TurnoverShrink20_60",
      "required_observation_count": 80,
      "source_field_names": [
        "turnover_float",
        "turnover_field_status",
        "share_field_status",
        "provider_turnover_crosscheck_status",
        "volume_shares",
        "float_share_shares",
        "trading_status",
        "corporate_action_flag",
        "suspension_flag",
        "corporate_action_types_in_window",
        "share_comparability_corporate_action_in_window",
        "common_share_basis_policy",
        "volume_comparability_policy"
      ],
      "formula": "mean_recent_20_turnover_float_over_mean_prior_non_overlapping_60_turnover_float",
      "readiness_gate": "R0_T03_V_LAYER_TURNOVER_READINESS_CONTRACT_V1"
    },
    {
      "indicator_id": "V2_LogAmount20_base",
      "raw_metric_name": "LogAmount20",
      "required_observation_count": 20,
      "source_field_names": [
        "amount_yuan",
        "amount_unit",
        "amount_volume_unit_status",
        "zero_amount_flag",
        "trading_status",
        "suspension_flag"
      ],
      "formula": "log_mean_recent_20_amount_yuan",
      "downstream_indicator": "V2_AmountLevel20Pct_in_R0_T05"
    }
  ],
