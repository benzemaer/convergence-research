{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/d3_t12_open_candidate_gate_contract.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "config_version",
    "contract_id",
    "task_id",
    "contract_status",
    "contract_scope",
    "d3_candidate_generation_is_research_agnostic",
    "downstream_consumer_readiness_evaluated_by_consumer_task",
    "formal_release_gate_separate",
    "r_stage_specific_readiness_not_hardcoded_in_d3",
    "supported_consumer_stage_namespace",
    "formal_data_version_authorized",
    "pcvt_metric_calculation_authorized",
    "future_label_generation_authorized",
    "returns_generation_authorized",
    "backtest_generation_authorized",
    "portfolio_generation_authorized"
  ],
  "properties": {
    "$schema": {
      "const": "../../schemas/d3_t12_open_candidate_gate_contract.schema.json"
    },
    "config_version": { "const": "1.0.0" },
    "contract_id": {
      "const": "D3_T12_OPEN_CANDIDATE_GATE_CONTRACT_V1"
    },
    "task_id": { "const": "D3-T12" },
    "contract_status": { "const": "accepted" },
    "contract_scope": {
      "const": "open_candidate_generation_and_consumer_readiness_decoupling"
    },
    "d3_candidate_generation_is_research_agnostic": { "const": true },
    "downstream_consumer_readiness_evaluated_by_consumer_task": {
      "const": true
    },
    "formal_release_gate_separate": { "const": true },
    "r_stage_specific_readiness_not_hardcoded_in_d3": { "const": true },
    "supported_consumer_stage_namespace": {
      "type": "array",
      "prefixItems": [
        { "const": "R0" },
        { "const": "R1" },
        { "const": "R2" },
        { "const": "R3" },
        { "const": "R4" },
        { "const": "R5" },
        { "const": "R6" },
        { "const": "future_research_routes" }
      ],
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true
    },
    "formal_data_version_authorized": { "const": false },
    "pcvt_metric_calculation_authorized": { "const": false },
    "future_label_generation_authorized": { "const": false },
    "returns_generation_authorized": { "const": false },
    "backtest_generation_authorized": { "const": false },
    "portfolio_generation_authorized": { "const": false }
  }
}
