{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/sidecar/exp_a02_authorized_input_manifest.schema.json",
  "title": "EXP-A02 authorized input manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "manifest_type", "manifest_version", "task_id", "authorized_for_task", "formal_data_version", "authorization", "input_artifacts", "cross_artifact_bindings"],
  "properties": {
    "$schema": {"const": "../../schemas/sidecar/exp_a02_authorized_input_manifest.schema.json"},
    "manifest_type": {"enum": ["exp_a02_authorized_input_manifest", "exp_a02_synthetic_input_manifest"]},
    "manifest_version": {"const": "1.0.0"},
    "task_id": {"const": "EXP-A02"},
    "authorized_for_task": {"const": "EXP-A02"},
    "formal_data_version": {"const": false},
    "authorization": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "formal_run_allowed", "evidence"],
      "properties": {"status": {"enum": ["approved", "synthetic_fixture_only"]}, "formal_run_allowed": {"const": false}, "evidence": {"type": "string", "minLength": 1}}
    },
    "input_artifacts": {
      "type": "object", "additionalProperties": false,
      "required": ["exp_a01_accepted_result_handoff", "exp_a01_raw_metrics", "exp_a01_manifest", "exp_a01_validator_result", "exp_a01_anomaly_scan"],
      "properties": {
        "exp_a01_accepted_result_handoff": {"$ref": "#/$defs/artifact"},
        "exp_a01_raw_metrics": {"$ref": "#/$defs/artifact"},
        "exp_a01_manifest": {"$ref": "#/$defs/artifact"},
        "exp_a01_validator_result": {"$ref": "#/$defs/artifact"},
        "exp_a01_anomaly_scan": {"$ref": "#/$defs/artifact"}
      }
    },
    "cross_artifact_bindings": {
      "type": "object", "additionalProperties": false,
      "required": ["accepted_run_id", "implementation_sha", "result_commit", "raw_artifact_sha256", "a01_manifest_sha256", "validator_status", "anomaly_status"],
      "properties": {
        "accepted_run_id": {"const": "EXP-A01-20260717T040145984Z"},
        "implementation_sha": {"const": "c9a52dc29f7d41c85ab416e99bb9ef8cc6411b9d"},
        "result_commit": {"const": "b7be2577233c045e507efe05d20601a20d373c9b"},
        "raw_artifact_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "a01_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "validator_status": {"const": "passed"},
        "anomaly_status": {"const": "passed"}
      }
    }
  },
  "$defs": {
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["artifact_id", "artifact_kind", "filename", "path", "path_policy", "sha256"],
      "properties": {
        "artifact_id": {"type": "string", "minLength": 1},
        "artifact_kind": {"enum": ["handoff_json", "duckdb_table", "a01_manifest_json", "a01_validator_json", "a01_anomaly_json"]},
        "filename": {"type": "string", "minLength": 1},
        "path": {"type": "string", "minLength": 1},
        "path_policy": {"enum": ["manifest_relative", "absolute_external", "basename_local_only", "synthetic_fixture"]},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "table": {"type": "string", "minLength": 1},
        "row_count": {"type": "integer", "minimum": 0},
        "required_columns": {"type": "array", "items": {"type": "string"}},
        "required_json_fields": {"type": "array", "items": {"type": "string"}},
        "security_count": {"type": "integer", "minimum": 0},
        "date_min": {"type": "string", "format": "date"},
        "date_max": {"type": "string", "format": "date"}
      }
    }
  }
}
