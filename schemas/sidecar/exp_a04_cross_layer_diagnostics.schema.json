{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/sidecar/exp_a04_cross_layer_diagnostics.schema.json",
  "title": "EXP-A04 cross-layer diagnostics contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "config_version", "task_id", "experiment_id", "program_id", "experiment_name", "research_route", "workflow_mode", "phase", "program_phase", "implementation_review_status", "reviewed_implementation_sha", "formal_run_allowed", "formal_run_status", "formal_run_executed", "formal_artifacts_generated", "result_review_status", "EXP_A04_started", "EXP_A05_started", "A_layer_registered", "PCATV_created", "formal_data_version", "mainline_task_unchanged", "mainline_current_task", "upstream", "candidate_universe", "pcvt_indicator_registry", "key_mapping", "calendar_years", "pair_registry", "correlation", "tail_policy", "hard_collision_gate", "investigation_policy", "output_contract", "analysis_headings", "governance", "execution_contract"],
  "properties": {
    "$schema": {"const": "../../schemas/sidecar/exp_a04_cross_layer_diagnostics.schema.json"},
    "config_version": {"const": "1.0.0"}, "task_id": {"const": "EXP-A04"}, "experiment_id": {"const": "EXP-A04"}, "program_id": {"const": "EXP-A"}, "experiment_name": {"const": "A层候选跨层诊断"}, "research_route": {"const": "sidecar_exploration"}, "workflow_mode": {"const": "long_lived_same_pr"}, "phase": {"const": "A04_cross_layer_diagnostics_implementation_review"}, "program_phase": {"const": "A04_cross_layer_diagnostics"}, "implementation_review_status": {"const": "pending"}, "reviewed_implementation_sha": {"const": ""}, "formal_run_allowed": {"const": false}, "formal_run_status": {"const": "not_started"}, "formal_run_executed": {"const": false}, "formal_artifacts_generated": {"const": false}, "result_review_status": {"const": "not_started"}, "EXP_A04_started": {"const": true}, "EXP_A05_started": {"const": false}, "A_layer_registered": {"const": false}, "PCATV_created": {"const": false}, "formal_data_version": {"const": false}, "mainline_task_unchanged": {"const": true}, "mainline_current_task": {"const": "R3-T02"},
    "upstream": {"type": "object", "additionalProperties": false, "required": ["a03_accepted_handoff", "pcvt_accepted_handoff", "a01_raw_table", "pcvt_raw_table", "a01_raw_binding", "pcvt_raw_binding"], "properties": {"a03_accepted_handoff": {"type": "string"}, "pcvt_accepted_handoff": {"type": "string"}, "a01_raw_table": {"const": "exp_a01_raw_metrics"}, "pcvt_raw_table": {"const": "r0_t04_raw_metric_results"}, "a01_raw_binding": {"$ref": "#/$defs/binding"}, "pcvt_raw_binding": {"allOf": [{"$ref": "#/$defs/binding"}, {"type": "object", "required": ["table"], "properties": {"table": {"const": "r0_t04_raw_metric_results"}}}]}}},
    "candidate_universe": {"type": "object", "additionalProperties": false, "required": ["candidate_ids", "short_ids", "a_validity_status", "a_raw_finite_required", "key_fields"], "properties": {"candidate_ids": {"const": ["A1_LogBodyCenterToMACloudCenter_5_60", "A2_BodyCenterOutsideMACloudRate20_5_60", "A2b_BodyToMACloudGapMean20_5_60"]}, "short_ids": {"const": {"A1_LogBodyCenterToMACloudCenter_5_60": "A1", "A2_BodyCenterOutsideMACloudRate20_5_60": "A2", "A2b_BodyToMACloudGapMean20_5_60": "A2b"}}, "a_validity_status": {"const": "valid"}, "a_raw_finite_required": {"const": true}, "key_fields": {"const": ["security_id", "trading_date", "observation_sequence"]}}},
    "pcvt_indicator_registry": {"type": "array", "minItems": 8, "maxItems": 8, "items": {"$ref": "#/$defs/indicator"}},
    "key_mapping": {"type": "object", "additionalProperties": false, "required": ["a", "pcvt", "join_policy"], "properties": {"a": {"const": {"security_id": "security_id", "trading_date": "trading_date", "observation_sequence": "observation_sequence"}}, "pcvt": {"const": {"security_id": "security_id", "trading_date": "trading_date", "observation_sequence": null}}, "join_policy": {"const": "security_id+trading_date_after_strict_uniqueness_proof"}}},
    "calendar_years": {"const": [2016, 2017, 2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026]},
    "pair_registry": {"type": "object", "additionalProperties": false, "required": ["a_candidate_count", "pcvt_indicator_count", "pair_count", "pair_id_format", "direction_required"], "properties": {"a_candidate_count": {"const": 3}, "pcvt_indicator_count": {"const": 8}, "pair_count": {"const": 24}, "pair_id_format": {"const": "<A_SHORT_ID>__<PCVT_INDICATOR_ID>"}, "direction_required": {"const": "lower_raw_is_more_convergent"}}},
    "correlation": {"type": "object", "additionalProperties": false, "required": ["pearson", "spearman", "rank_method", "rank_pct", "security_min_common_rows", "year_common_rows_required"], "properties": {"pearson": {"const": "corr(a_raw,pcvt_raw)"}, "spearman": {"const": "corr(a_midrank,pcvt_midrank)"}, "rank_method": {"const": "RANK plus tie-count midrank"}, "rank_pct": {"const": "(midrank-0.5)/N"}, "security_min_common_rows": {"const": 100}, "year_common_rows_required": {"const": true}}},
    "tail_policy": {"type": "object", "additionalProperties": false, "required": ["fractions", "quantile_function", "selection"], "properties": {"fractions": {"const": [0.01, 0.05, 0.1]}, "quantile_function": {"const": "QUANTILE_DISC"}, "selection": {"const": "raw_value <= threshold including all threshold ties"}}},
    "hard_collision_gate": {"type": "object", "additionalProperties": false, "required": ["all_of", "overall_spearman_min", "minimum_year_spearman_min", "eligible_security_spearman_q10_min", "tail_jaccard_005_min", "tail_jaccard_010_min", "pearson_used", "absolute_correlation_used"], "properties": {"all_of": {"const": true}, "overall_spearman_min": {"const": 0.95}, "minimum_year_spearman_min": {"const": 0.9}, "eligible_security_spearman_q10_min": {"const": 0.8}, "tail_jaccard_005_min": {"const": 0.8}, "tail_jaccard_010_min": {"const": 0.8}, "pearson_used": {"const": false}, "absolute_correlation_used": {"const": false}}},
    "investigation_policy": {"type": "object", "additionalProperties": false, "required": ["common_rate_smaller_min", "eligible_security_min", "year_spearman_range_max", "security_spearman_iqr10_90_max", "overall_spearman_investigate_below_or_equal", "near_gate_distance"], "properties": {"common_rate_smaller_min": {"const": 0.8}, "eligible_security_min": {"const": 720}, "year_spearman_range_max": {"const": 0.3}, "security_spearman_iqr10_90_max": {"const": 0.4}, "overall_spearman_investigate_below_or_equal": {"const": -0.5}, "near_gate_distance": {"const": 0.02}}},
    "output_contract": {"type": "object", "additionalProperties": false, "required": ["files", "row_counts", "raw_duckdb_generated", "forbidden_extensions"], "properties": {"files": {"const": ["exp_a04_indicator_registry.csv", "exp_a04_pairwise_coverage.csv", "exp_a04_pairwise_overall.csv", "exp_a04_pairwise_year.csv", "exp_a04_pairwise_security.csv", "exp_a04_tail_overlap.csv", "exp_a04_layer_summary.csv", "exp_a04_candidate_summary.csv", "exp_a04_cross_layer_disposition.json", "exp_a04_manifest.json", "exp_a04_validator_result.json", "exp_a04_anomaly_scan.json", "exp_a04_result_analysis.md"]}, "row_counts": {"const": {"exp_a04_indicator_registry.csv": 11, "exp_a04_pairwise_coverage.csv": 24, "exp_a04_pairwise_overall.csv": 24, "exp_a04_pairwise_year.csv": 264, "exp_a04_pairwise_security.csv": 19200, "exp_a04_tail_overlap.csv": 72, "exp_a04_layer_summary.csv": 12, "exp_a04_candidate_summary.csv": 3}}, "raw_duckdb_generated": {"const": false}, "forbidden_extensions": {"const": [".duckdb", ".parquet"]}}},
    "analysis_headings": {"const": ["## 1. Actual run / reviewed SHA", "## 2. Accepted EXP-A03 handoff", "## 3. Accepted PCVT raw handoff", "## 4. Input artifacts and lineage", "## 5. Frozen indicator registry", "## 6. Pairwise common-universe coverage", "## 7. Overall cross-layer relationships", "## 8. Year stability", "## 9. Security stability", "## 10. Low-tail identity overlap", "## 11. Hard collision gate results", "## 12. Layer summaries", "## 13. Candidate summaries", "## 14. Provisional A05 carry-forward status", "## 15. Full invariant validation", "## 16. Independent aggregate recomputation", "## 17. Anomaly scan", "## 18. Supported conclusions", "## 19. Unsupported conclusions", "## 20. Readiness for Formal-result review"]},
    "governance": {"type": "object", "additionalProperties": false, "required": ["EXP_A04_started", "EXP_A05_started", "A_layer_registered", "PCATV_created", "candidate_set_for_A05", "decision_status"], "properties": {"EXP_A04_started": {"const": true}, "EXP_A05_started": {"const": false}, "A_layer_registered": {"const": false}, "PCATV_created": {"const": false}, "candidate_set_for_A05": {"const": ["A1", "A2", "A2b"]}, "decision_status": {"const": "provisional_A04_diagnostic"}}},
    "execution_contract": {"type": "object", "additionalProperties": false, "required": ["implementation_synthetic_only", "formal_execution_capable", "read_only_upstream_raw", "copy_upstream_raw_forbidden", "new_persistent_duckdb_forbidden", "pandas_forbidden", "full_raw_python_iteration_forbidden", "single_core_validator", "single_anomaly_scan", "failure_package_preservation", "formal_data_version"], "properties": {"implementation_synthetic_only": {"const": false}, "formal_execution_capable": {"const": true}, "read_only_upstream_raw": {"const": true}, "copy_upstream_raw_forbidden": {"const": true}, "new_persistent_duckdb_forbidden": {"const": true}, "pandas_forbidden": {"const": true}, "full_raw_python_iteration_forbidden": {"const": true}, "single_core_validator": {"const": true}, "single_anomaly_scan": {"const": true}, "failure_package_preservation": {"const": true}, "formal_data_version": {"const": false}}}
  },
  "$defs": {
    "binding": {"type": "object", "additionalProperties": false, "required": ["path_policy", "sha256", "row_count", "expected_key_count", "security_count", "date_min", "date_max"], "properties": {"path_policy": {"enum": ["absolute_declared_path", "relative_to_manifest", "synthetic_fixture"]}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}, "row_count": {"type": "integer", "minimum": 0}, "expected_key_count": {"type": "integer", "minimum": 0}, "security_count": {"type": "integer", "minimum": 0}, "date_min": {"type": "string"}, "date_max": {"type": "string"}, "table": {"type": "string"}}},
    "indicator": {"type": "object", "additionalProperties": false, "required": ["indicator_id", "layer", "raw_metric_name", "raw_source_indicator_id", "raw_value_direction"], "properties": {"indicator_id": {"type": "string"}, "layer": {"enum": ["P", "C", "T", "V"]}, "raw_metric_name": {"type": "string"}, "raw_source_indicator_id": {"type": "string"}, "raw_value_direction": {"const": "lower_is_more_convergent"}}}
  }
}
