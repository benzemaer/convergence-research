{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/sidecar/exp_a01_authorized_input_manifest.schema.json",
  "title": "EXP-A01 authorized input manifest",
  "type": "object",
  "required": [
    "manifest_type",
    "schema_version",
    "authorized_for_task",
    "authorized_research_candidate_input",
    "formal_data_version",
    "authorization",
    "input_artifacts",
    "cross_artifact_bindings",
    "d3_t08_source_binding"
  ],
  "properties": {
    "manifest_type": {"const": "exp_a01_authorized_input_manifest"},
    "schema_version": {"const": "exp_a01_authorized_input_manifest.v1"},
    "task_id": {"const": "EXP-A01"},
    "authorized_for_task": {"const": "EXP-A01"},
    "authorized_research_candidate_input": {"const": true},
    "formal_data_version": {"const": false},
    "authorization": {
      "type": "object",
      "required": ["authorization_status", "authorized_by", "authorized_at", "authorization_evidence"],
      "properties": {
        "authorization_status": {"const": "authorized_for_exp_a01"},
        "authorized_by": {"type": "string", "minLength": 1},
        "authorized_at": {"type": "string", "minLength": 1},
        "authorization_evidence": {"type": "string", "minLength": 1}
      }
    },
    "input_artifacts": {
      "type": "object",
      "required": [
        "d3_t07_candidate_daily_observation",
        "d3_t07_handoff_report",
        "d3_t07_quality_report",
        "d3_t08_handoff_report",
        "d3_t08_quality_report",
        "expected_price_observation_index"
      ],
      "properties": {
        "d3_t07_candidate_daily_observation": {"$ref": "#/$defs/artifact"},
        "d3_t07_handoff_report": {"$ref": "#/$defs/artifact"},
        "d3_t07_quality_report": {"$ref": "#/$defs/artifact"},
        "d3_t08_handoff_report": {"$ref": "#/$defs/artifact"},
        "d3_t08_quality_report": {"$ref": "#/$defs/artifact"},
        "expected_price_observation_index": {"$ref": "#/$defs/artifact"}
      }
    },
    "cross_artifact_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "d3_t07_candidate_sha256",
        "d3_t07_quality_sha256",
        "d3_t07_handoff_sha256",
        "d3_t08_quality_sha256",
        "d3_t08_handoff_sha256",
        "expected_index_sha256"
      ],
      "properties": {
        "d3_t07_candidate_sha256": {"$ref": "#/$defs/sha256"},
        "d3_t07_quality_sha256": {"$ref": "#/$defs/sha256"},
        "d3_t07_handoff_sha256": {"$ref": "#/$defs/sha256"},
        "d3_t08_quality_sha256": {"$ref": "#/$defs/sha256"},
        "d3_t08_handoff_sha256": {"$ref": "#/$defs/sha256"},
        "expected_index_sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "d3_t08_source_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_task_id", "source_candidate_artifact_id", "source_candidate_sha256"],
      "properties": {
        "source_task_id": {"const": "D3-T07"},
        "source_candidate_artifact_id": {"const": "d3_t07_candidate_daily_observation"},
        "source_candidate_sha256": {"$ref": "#/$defs/sha256"}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "artifact": {
      "type": "object",
      "additionalProperties": true,
      "required": ["artifact_id", "path", "filename", "sha256", "source_contract", "source_role", "formal_data_version"],
      "properties": {
        "artifact_id": {"type": "string", "pattern": "^[a-z][a-z0-9_]*$"},
        "path": {"type": "string", "minLength": 1},
        "path_policy": {"enum": ["basename_local_only"]},
        "filename": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"},
        "source_contract": {"type": "string", "minLength": 1},
        "source_role": {"type": "string", "minLength": 1},
        "formal_data_version": {"const": false},
        "table": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
        "row_count": {"type": "integer", "minimum": 0},
        "required_columns": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "required_json_fields": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
