{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benzemaer/convergence-research/schemas/d2_continuous_price_construction_contract.schema.json",
  "title": "D2 Continuous Price Construction Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["config_version", "task_id", "contract_id", "contract_status", "target_table", "data_version", "universe_id", "time_segment_id", "depends_on", "required_fields", "synthetic_input_raw_fields", "synthetic_input_factor_fields", "primary_key", "authorization", "construction_rule", "blocking_conditions", "prohibited_row_fields", "mechanical_gap_boundary", "d2_t06_boundary"],
  "properties": {
    "$schema": {"type": "string"},
    "config_version": {"const": "1.0.0"},
    "task_id": {"const": "D2-T05"},
    "contract_id": {"const": "D2_CONTINUOUS_PRICE_CONSTRUCTION_CONTRACT_V1"},
    "contract_status": {"const": "accepted"},
    "target_table": {"const": "d2.adjusted_market_prices"},
    "data_version": {"const": "D2_CONTINUOUS_PRICE_CONSTRUCTION_BLOCKED_PENDING_RAW_AND_FACTOR_AUTHORIZATION_V1"},
    "universe_id": {"const": "CSI800_STATIC_2026_06"},
    "time_segment_id": {"const": "DR001_STATIC_BACKFILL_20160101_20260630"},
    "depends_on": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1},
      "allOf": [
        {"contains": {"const": "D2_RAW_MARKET_PRICES_MATERIALIZATION_CONTRACT_V1"}},
        {"contains": {"const": "D2_ADJUSTMENT_FACTOR_ASOF_CONTRACT_V1"}},
        {"contains": {"const": "D2_CSI800_STATIC_2026_06_MEMBERSHIP_ALIGNMENT_V1"}},
        {"contains": {"const": "D1_CORPORATE_ACTIONS_ADJUSTMENT_CONTRACT_V1"}},
        {"contains": {"const": "D0_DATA_PRODUCT_CONTRACTS_V1"}},
        {"contains": {"const": "D0_SOURCE_REGISTRY_V1"}},
        {"contains": {"const": "DR-001"}}
      ]
    },
    "required_fields": {"$ref": "#/$defs/adjusted_market_prices_required_fields"},
    "synthetic_input_raw_fields": {"$ref": "#/$defs/synthetic_input_raw_fields"},
    "synthetic_input_factor_fields": {"$ref": "#/$defs/synthetic_input_factor_fields"},
    "primary_key": {"$ref": "#/$defs/adjusted_market_prices_primary_key"},
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["continuous_price_construction_authorized", "adjusted_price_generation_authorized", "formal_ingestion_authorized", "duckdb_write_authorized", "real_continuous_price_artifact_authorized", "synthetic_test_only"],
      "properties": {
        "continuous_price_construction_authorized": {"const": false},
        "adjusted_price_generation_authorized": {"const": false},
        "formal_ingestion_authorized": {"const": false},
        "duckdb_write_authorized": {"const": false},
        "real_continuous_price_artifact_authorized": {"const": false},
        "synthetic_test_only": {"const": true}
      }
    },
    "construction_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["synthetic_construction_rule", "identity_no_adjustment_rule", "factor_adjusted_rule", "adjustment_factor_positive", "adjusted_ohlc_order_required", "reverse_check_rule", "reverse_check_tolerance_abs", "reverse_check_tolerance_rel", "factor_as_of_time_not_after_observation_cutoff", "mechanical_gap_market_signal_prohibited"],
      "properties": {
        "synthetic_construction_rule": {"const": "multiplicative_factor"},
        "identity_no_adjustment_rule": {"type": "string", "minLength": 1},
        "factor_adjusted_rule": {"type": "string", "minLength": 1},
        "adjustment_factor_positive": {"const": true},
        "adjusted_ohlc_order_required": {"const": true},
        "reverse_check_rule": {"type": "string", "minLength": 1},
        "reverse_check_tolerance_abs": {"type": "number", "exclusiveMinimum": 0, "maximum": 1e-6},
        "reverse_check_tolerance_rel": {"type": "number", "exclusiveMinimum": 0, "maximum": 1e-6},
        "factor_as_of_time_not_after_observation_cutoff": {"const": true},
        "mechanical_gap_market_signal_prohibited": {"const": true}
      }
    },
    "blocking_conditions": {"$ref": "#/$defs/blocking_conditions"},
    "prohibited_row_fields": {"$ref": "#/$defs/prohibited_row_fields"},
    "mechanical_gap_boundary": {"type": "string", "minLength": 1},
    "d2_t06_boundary": {"type": "string", "minLength": 1}
  },
  "$defs": {
    "adjusted_market_prices_required_fields": {
      "type": "array",
      "minItems": 17,
      "maxItems": 17,
      "uniqueItems": true,
      "items": {
        "enum": [
          "data_version",
          "universe_id",
          "time_segment_id",
          "security_id",
          "trading_date",
          "adj_open",
          "adj_high",
          "adj_low",
          "adj_close",
          "adjustment_factor",
          "adjustment_method",
          "factor_as_of_time",
          "corporate_action_flag",
          "adjustment_revision",
          "source_registry_id",
          "source_snapshot_id",
          "run_id"
        ]
      },
      "allOf": [
        {"contains": {"const": "data_version"}},
        {"contains": {"const": "universe_id"}},
        {"contains": {"const": "time_segment_id"}},
        {"contains": {"const": "security_id"}},
        {"contains": {"const": "trading_date"}},
        {"contains": {"const": "adj_open"}},
        {"contains": {"const": "adj_high"}},
        {"contains": {"const": "adj_low"}},
        {"contains": {"const": "adj_close"}},
        {"contains": {"const": "adjustment_factor"}},
        {"contains": {"const": "adjustment_method"}},
        {"contains": {"const": "factor_as_of_time"}},
        {"contains": {"const": "corporate_action_flag"}},
        {"contains": {"const": "adjustment_revision"}},
        {"contains": {"const": "source_registry_id"}},
        {"contains": {"const": "source_snapshot_id"}},
        {"contains": {"const": "run_id"}}
      ]
    },
    "synthetic_input_raw_fields": {
      "type": "array",
      "minItems": 10,
      "maxItems": 10,
      "uniqueItems": true,
      "items": {
        "enum": [
          "raw_open",
          "raw_high",
          "raw_low",
          "raw_close",
          "volume",
          "amount",
          "trading_status",
          "price_limit_status",
          "raw_source_snapshot_id",
          "raw_observed_at"
        ]
      },
      "allOf": [
        {"contains": {"const": "raw_open"}},
        {"contains": {"const": "raw_high"}},
        {"contains": {"const": "raw_low"}},
        {"contains": {"const": "raw_close"}},
        {"contains": {"const": "volume"}},
        {"contains": {"const": "amount"}},
        {"contains": {"const": "trading_status"}},
        {"contains": {"const": "price_limit_status"}},
        {"contains": {"const": "raw_source_snapshot_id"}},
        {"contains": {"const": "raw_observed_at"}}
      ]
    },
    "synthetic_input_factor_fields": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {
        "enum": [
          "adjustment_factor",
          "adjustment_method",
          "factor_as_of_time",
          "corporate_action_flag",
          "adjustment_revision",
          "factor_source_snapshot_id"
        ]
      },
      "allOf": [
        {"contains": {"const": "adjustment_factor"}},
        {"contains": {"const": "adjustment_method"}},
        {"contains": {"const": "factor_as_of_time"}},
        {"contains": {"const": "corporate_action_flag"}},
        {"contains": {"const": "adjustment_revision"}},
        {"contains": {"const": "factor_source_snapshot_id"}}
      ]
    },
    "adjusted_market_prices_primary_key": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {
        "enum": [
          "data_version",
          "universe_id",
          "security_id",
          "trading_date",
          "adjustment_revision"
        ]
      },
      "allOf": [
        {"contains": {"const": "data_version"}},
        {"contains": {"const": "universe_id"}},
        {"contains": {"const": "security_id"}},
        {"contains": {"const": "trading_date"}},
        {"contains": {"const": "adjustment_revision"}}
      ]
    },
    "blocking_conditions": {
      "type": "array",
      "minItems": 18,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1},
      "allOf": [
        {"contains": {"const": "raw_price_materialization_blocked"}},
        {"contains": {"const": "adjustment_factor_materialization_blocked"}},
        {"contains": {"const": "source_terms_pending_for_formal_ingestion"}},
        {"contains": {"const": "missing_raw_market_prices"}},
        {"contains": {"const": "missing_adjustment_factor"}},
        {"contains": {"const": "missing_factor_as_of_time"}},
        {"contains": {"const": "factor_as_of_time_after_observation_cutoff"}},
        {"contains": {"const": "adjustment_factor_nonpositive"}},
        {"contains": {"const": "adjusted_ohlc_order_invalid"}},
        {"contains": {"const": "reverse_check_failed"}},
        {"contains": {"const": "future_corporate_action_knowledge_used"}},
        {"contains": {"const": "corporate_action_flag_silently_false"}},
        {"contains": {"const": "mechanical_gap_misattributed_as_market_gap"}},
        {"contains": {"const": "unknown_adjustment_method"}},
        {"contains": {"const": "unknown_adjustment_revision"}},
        {"contains": {"const": "duckdb_write_attempted"}},
        {"contains": {"const": "real_continuous_price_artifact_generated"}},
        {"contains": {"const": "d2_t06_attempted_before_d2_t05_unblocked"}}
      ]
    },
    "prohibited_row_fields": {
      "type": "array",
      "minItems": 11,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1},
      "allOf": [
        {"contains": {"const": "raw_gap"}},
        {"contains": {"const": "adjusted_gap"}},
        {"contains": {"const": "gap_attribution"}},
        {"contains": {"const": "future_return"}},
        {"contains": {"const": "label"}},
        {"contains": {"const": "event_type"}},
        {"contains": {"const": "pcvt_state"}},
        {"contains": {"const": "ticker"}},
        {"contains": {"const": "exchange"}},
        {"contains": {"const": "source_symbol"}},
        {"contains": {"const": "vendor_payload"}}
      ]
    }
  }
}
