{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benzemaer/convergence-research/schemas/artifact_manifest.schema.json",
  "title": "Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "artifact_id",
    "artifact_version",
    "artifact_type",
    "lifecycle",
    "evidence_status",
    "stage",
    "step",
    "data_version",
    "state_definition_version",
    "code_commit",
    "config_hash",
    "environment_lock_hash",
    "run_id",
    "input_hashes",
    "output_hashes",
    "schema_version",
    "created_at",
    "owner",
    "review_record",
    "allowed_downstream_use"
  ],
  "properties": {
    "manifest_version": {"const": "1.0.0"},
    "artifact_id": {"type": "string", "minLength": 1},
    "artifact_version": {"type": "string", "minLength": 1},
    "artifact_type": {
      "enum": [
        "dataset",
        "factor",
        "state_day",
        "confirmed_interval",
        "event",
        "risk_set",
        "label",
        "chart",
        "statistical_summary",
        "null_model_result",
        "backtest_result",
        "report",
        "conclusion_record",
        "other"
      ]
    },
    "lifecycle": {
      "enum": ["draft", "candidate", "validated", "frozen", "released"]
    },
    "evidence_status": {
      "enum": ["exploratory", "candidate", "validated", "frozen", "released"]
    },
    "stage": {"pattern": "^(D[0-3]|R[0-6])$"},
    "step": {"type": "string", "minLength": 1},
    "data_version": {"type": "string", "minLength": 1},
    "state_definition_version": {"type": ["string", "null"]},
    "code_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "config_hash": {"$ref": "#/$defs/sha256"},
    "environment_lock_hash": {"$ref": "#/$defs/sha256"},
    "run_id": {"type": "string", "minLength": 1},
    "input_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/file_hash"}
    },
    "output_hashes": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/file_hash"}
    },
    "schema_version": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "owner": {"type": "string", "minLength": 1},
    "supersedes": {"type": ["string", "null"]},
    "review_record": {"$ref": "#/$defs/review_record"},
    "allowed_downstream_use": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {"properties": {"lifecycle": {"const": "draft"}}},
      "then": {"properties": {"evidence_status": {"const": "exploratory"}}}
    },
    {
      "if": {"properties": {"lifecycle": {"const": "candidate"}}},
      "then": {"properties": {"evidence_status": {"const": "candidate"}}}
    },
    {
      "if": {"properties": {"lifecycle": {"const": "validated"}}},
      "then": {"properties": {"evidence_status": {"const": "validated"}}}
    },
    {
      "if": {"properties": {"lifecycle": {"const": "frozen"}}},
      "then": {"properties": {"evidence_status": {"const": "frozen"}}}
    },
    {
      "if": {"properties": {"lifecycle": {"const": "released"}}},
      "then": {"properties": {"evidence_status": {"const": "released"}}}
    },
    {
      "if": {
        "properties": {
          "lifecycle": {"enum": ["validated", "frozen", "released"]}
        }
      },
      "then": {
        "properties": {
          "review_record": {
            "properties": {
              "status": {"const": "approved"},
              "reviewed_by": {"type": "string", "minLength": 1},
              "reviewed_at": {"type": "string", "format": "date-time"}
            }
          },
          "allowed_downstream_use": {"minItems": 1}
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "file_hash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "review_record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_by", "reviewed_at", "gate"],
      "properties": {
        "status": {"enum": ["pending", "approved", "rejected"]},
        "reviewed_by": {"type": ["string", "null"]},
        "reviewed_at": {"type": ["string", "null"], "format": "date-time"},
        "gate": {"pattern": "^G[0-7]$"}
      }
    }
  }
}
