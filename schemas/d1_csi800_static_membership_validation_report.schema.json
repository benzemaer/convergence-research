{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benzemaer/convergence-research/schemas/d1_csi800_static_membership_validation_report.schema.json",
  "title": "D1 CSI800 Static Membership Validation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "report_version",
    "task_id",
    "universe_id",
    "index_code",
    "source_registry_id",
    "source_snapshot_id",
    "raw_evidence_path",
    "raw_evidence_sha256_expected",
    "raw_evidence_sha256_actual",
    "validator_script",
    "validator_commit",
    "validation_status",
    "validation_reason",
    "member_count_observed",
    "expected_member_count",
    "mapping_readiness_summary",
    "row_level_data_committed",
    "raw_bytes_committed",
    "duckdb_written",
    "run_manifest_created",
    "dataset_manifest_created",
    "materialization_authorized",
    "member_rows_materialized",
    "downstream_decision",
    "static_cohort_bias_warning",
    "report_boundary"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "report_id": {
      "const": "D1_T04_CSI800_STATIC_2026_06_EVIDENCE_VALIDATION_REPORT_V1"
    },
    "report_version": {"const": "1.0.0"},
    "task_id": {"const": "D1-T04"},
    "universe_id": {"const": "CSI800_STATIC_2026_06"},
    "index_code": {"const": "000906"},
    "source_registry_id": {"const": "CSINDEX_OFFICIAL"},
    "source_snapshot_id": {"const": "CSINDEX_000906_20260703T100909Z"},
    "raw_evidence_path": {
      "const": "data/external/source=csindex/index=000906/snapshot=20260703T100909Z/000906cons.xls"
    },
    "raw_evidence_sha256_expected": {
      "const": "f8e4aa8d28bec4871fe6f582d4e5fc490c79312524a568de8f23b73e22b2b984"
    },
    "raw_evidence_sha256_actual": {"$ref": "#/$defs/sha256"},
    "validator_script": {
      "const": "scripts/validate_csi800_static_membership_materialization.py"
    },
    "validator_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "validation_status": {
      "enum": [
        "passed",
        "blocked_missing_evidence",
        "failed_hash_mismatch",
        "failed_parse",
        "failed_member_count",
        "failed_mapping_fields"
      ]
    },
    "validation_reason": {"type": "string", "minLength": 1},
    "member_count_observed": {"type": "integer", "minimum": 0},
    "expected_member_count": {"const": 800},
    "mapping_readiness_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_symbol_present",
        "ticker_present",
        "exchange_present",
        "security_id_mapping_reference_present",
        "row_level_detail_included"
      ],
      "properties": {
        "source_symbol_present": {"type": "boolean"},
        "ticker_present": {"type": "boolean"},
        "exchange_present": {"type": "boolean"},
        "security_id_mapping_reference_present": {"type": "boolean"},
        "row_level_detail_included": {"const": false}
      }
    },
    "row_level_data_committed": {"const": false},
    "raw_bytes_committed": {"const": false},
    "duckdb_written": {"const": false},
    "run_manifest_created": {"const": false},
    "dataset_manifest_created": {"const": false},
    "materialization_authorized": {"const": false},
    "member_rows_materialized": {"const": false},
    "downstream_decision": {
      "enum": [
        "evidence_validated_but_rows_not_materialized",
        "materialization_remains_blocked"
      ]
    },
    "static_cohort_bias_warning": {
      "type": "string",
      "allOf": [
        {"pattern": "static research cohort"},
        {"pattern": "not historical point-in-time CSI 800 membership"}
      ]
    },
    "report_boundary": {
      "type": "string",
      "allOf": [
        {"pattern": "aggregate evidence validation report only"},
        {"pattern": "not a materialization manifest"}
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"validation_status": {"const": "passed"}}},
      "then": {
        "properties": {
          "raw_evidence_sha256_actual": {
            "const": "f8e4aa8d28bec4871fe6f582d4e5fc490c79312524a568de8f23b73e22b2b984"
          },
          "member_count_observed": {"const": 800},
          "row_level_data_committed": {"const": false},
          "raw_bytes_committed": {"const": false},
          "duckdb_written": {"const": false},
          "run_manifest_created": {"const": false},
          "dataset_manifest_created": {"const": false},
          "materialization_authorized": {"const": false},
          "member_rows_materialized": {"const": false},
          "downstream_decision": {
            "const": "evidence_validated_but_rows_not_materialized"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "validation_status": {
            "enum": [
              "blocked_missing_evidence",
              "failed_hash_mismatch",
              "failed_parse",
              "failed_member_count",
              "failed_mapping_fields"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "downstream_decision": {"const": "materialization_remains_blocked"}
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
