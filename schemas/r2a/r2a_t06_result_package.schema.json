{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "r2a_t06_result_package.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id", "package_schema_version", "status", "scope_id",
    "q_selection_status", "canonical_dynamic_request_selected", "winner_selected",
    "accepted_run_id", "reviewed_implementation_sha", "reviewed_execution_sha",
    "owner_result_review", "result_analysis_status", "blocking_anomaly_count",
    "selected_exit_confirmation_m", "selection_principle", "selection_evidence",
    "formal_run_executed", "real_score_data_read", "formal_artifacts_generated",
    "R2A-T06_DONE", "R2A-T07_allowed_to_start", "R3_allowed_to_start",
    "files", "validation"
  ],
  "properties": {
    "task_id": {"const": "R2A-T06"},
    "package_schema_version": {"const": "r2a_t06_result_package.v1"},
    "status": {"enum": ["implementation_candidate", "formal_completed_pending_owner_review", "completed_accepted"]},
    "scope_id": {"const": "r2a_t06_consecutive_failure_exit_confirmation.v1"},
    "q_selection_status": {"const": "not_selected"},
    "canonical_dynamic_request_selected": {"const": false},
    "winner_selected": {"type": "boolean"},
    "accepted_run_id": {"type": ["string", "null"], "minLength": 1},
    "reviewed_implementation_sha": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/gitSha"}]},
    "reviewed_execution_sha": {"anyOf": [{"type": "null"}, {"$ref": "#/$defs/gitSha"}]},
    "owner_result_review": {"enum": ["pending", "accepted", "rejected"]},
    "result_analysis_status": {"enum": ["not_started", "completed_passed", "completed_blocked"]},
    "blocking_anomaly_count": {"type": ["integer", "null"], "minimum": 0},
    "selected_exit_confirmation_m": {"type": ["integer", "null"], "enum": [null, 1, 2, 3]},
    "selection_principle": {"const": "minimum_sufficient_complexity"},
    "selection_evidence": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
    "formal_run_executed": {"type": "boolean"},
    "real_score_data_read": {"type": "boolean"},
    "formal_artifacts_generated": {"type": "boolean"},
    "R2A-T06_DONE": {"enum": ["absent", "present"]},
    "R2A-T07_allowed_to_start": {"type": "boolean"},
    "R3_allowed_to_start": {"const": false},
    "files": {"type": "array", "items": {"$ref": "#/$defs/file"}},
    "validation": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "independent_recalculation", "accepted_daily_fact_immutability", "online_replay_equivalence", "deterministic_output", "parallel_consistency", "cross_q_nesting"],
      "properties": {
        "status": {"enum": ["pending", "passed", "failed"]},
        "independent_recalculation": {"type": "boolean"},
        "accepted_daily_fact_immutability": {"type": "boolean"},
        "online_replay_equivalence": {"type": "boolean"},
        "deterministic_output": {"type": "boolean"},
        "parallel_consistency": {"type": "boolean"},
        "cross_q_nesting": {"type": "boolean"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "implementation_candidate"}}, "required": ["status"]},
      "then": {"properties": {
        "accepted_run_id": {"const": null}, "reviewed_execution_sha": {"const": null},
        "owner_result_review": {"const": "pending"}, "result_analysis_status": {"const": "not_started"},
        "blocking_anomaly_count": {"const": null}, "selected_exit_confirmation_m": {"const": null},
        "selection_evidence": {"maxItems": 0}, "winner_selected": {"const": false},
        "formal_run_executed": {"const": false}, "real_score_data_read": {"const": false},
        "formal_artifacts_generated": {"const": false}, "R2A-T06_DONE": {"const": "absent"},
        "R2A-T07_allowed_to_start": {"const": false}, "files": {"maxItems": 0}
      }}
    },
    {
      "if": {"properties": {"status": {"const": "formal_completed_pending_owner_review"}}, "required": ["status"]},
      "then": {"properties": {
        "accepted_run_id": {"type": "string"}, "reviewed_implementation_sha": {"$ref": "#/$defs/gitSha"},
        "reviewed_execution_sha": {"$ref": "#/$defs/gitSha"}, "owner_result_review": {"const": "pending"},
        "result_analysis_status": {"enum": ["completed_passed", "completed_blocked"]},
        "blocking_anomaly_count": {"type": "integer"}, "selected_exit_confirmation_m": {"const": null},
        "selection_evidence": {"maxItems": 0}, "winner_selected": {"const": false},
        "formal_run_executed": {"const": true}, "real_score_data_read": {"const": true},
        "formal_artifacts_generated": {"const": true}, "R2A-T06_DONE": {"const": "absent"},
        "R2A-T07_allowed_to_start": {"const": false}, "files": {"$ref": "#/$defs/formalFiles"},
        "validation": {"$ref": "#/$defs/passedValidation"}
      }}
    },
    {
      "if": {"properties": {"status": {"const": "completed_accepted"}}, "required": ["status"]},
      "then": {"properties": {
        "accepted_run_id": {"type": "string"}, "reviewed_implementation_sha": {"$ref": "#/$defs/gitSha"},
        "reviewed_execution_sha": {"$ref": "#/$defs/gitSha"}, "owner_result_review": {"const": "accepted"},
        "result_analysis_status": {"const": "completed_passed"}, "blocking_anomaly_count": {"const": 0},
        "selected_exit_confirmation_m": {"enum": [1, 2, 3]}, "selection_evidence": {"minItems": 1},
        "winner_selected": {"const": true}, "formal_run_executed": {"const": true},
        "real_score_data_read": {"const": true}, "formal_artifacts_generated": {"const": true},
        "R2A-T06_DONE": {"const": "present"}, "R2A-T07_allowed_to_start": {"const": true},
        "files": {"$ref": "#/$defs/formalFiles"}, "validation": {"$ref": "#/$defs/passedValidation"}
      }}
    }
  ],
  "$defs": {
    "gitSha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "file": {
      "type": "object", "additionalProperties": false,
      "required": ["relative_path", "sha256", "byte_size", "storage_class"],
      "properties": {
        "relative_path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "byte_size": {"type": "integer", "minimum": 0},
        "storage_class": {"enum": ["compact_review", "repository_local_detail"]}
      }
    },
    "passedValidation": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "independent_recalculation", "accepted_daily_fact_immutability", "online_replay_equivalence", "deterministic_output", "parallel_consistency", "cross_q_nesting"],
      "properties": {
        "status": {"const": "passed"}, "independent_recalculation": {"const": true},
        "accepted_daily_fact_immutability": {"const": true}, "online_replay_equivalence": {"const": true},
        "deterministic_output": {"const": true}, "parallel_consistency": {"const": true},
        "cross_q_nesting": {"const": true}
      }
    },
    "formalFiles": {
      "type": "array", "minItems": 17, "maxItems": 17,
      "items": {"$ref": "#/$defs/file"},
      "allOf": [
        {"contains": {"properties": {"relative_path": {"const": "request_identity.json"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "input_manifest.json"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "run_summary.json"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "validation_receipt.json"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "result_analysis.md"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "false_run_length_profile.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "recovery_hazard_profile.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "candidate_exit_summary.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "recognition_lag_profile.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "post_recognition_reentry.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "episode_fragmentation_profile.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "exit_type_margin_profile.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "cross_q_nesting_validation.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "year_profile.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "security_profile.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "deterministic_episode_samples.csv"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1},
        {"contains": {"properties": {"relative_path": {"const": "t06_detail.duckdb"}}, "required": ["relative_path"]}, "minContains": 1, "maxContains": 1}
      ]
    }
  }
}
