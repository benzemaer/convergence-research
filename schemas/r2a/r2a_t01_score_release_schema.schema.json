{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/r2a/r2a_t01_score_release_schema.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "table_order", "tables"],
  "properties": {
    "schema_version": {"const": "r2a_t01_score_release_schema.v1"},
    "table_order": {"const": ["securities", "trading_sessions", "security_observation_spine", "dimension_definitions", "dimension_components", "daily_component_scores", "daily_dimension_scores"]},
    "tables": {
      "type": "object",
      "additionalProperties": false,
      "required": ["securities", "trading_sessions", "security_observation_spine", "dimension_definitions", "dimension_components", "daily_component_scores", "daily_dimension_scores"],
      "properties": {
        "securities": {"$ref": "#/$defs/table"},
        "trading_sessions": {"$ref": "#/$defs/table"},
        "security_observation_spine": {"$ref": "#/$defs/table"},
        "dimension_definitions": {"$ref": "#/$defs/table"},
        "dimension_components": {"$ref": "#/$defs/table"},
        "daily_component_scores": {"$ref": "#/$defs/table"},
        "daily_dimension_scores": {"$ref": "#/$defs/table"}
      }
    }
  },
  "$defs": {
    "table": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_key", "columns"],
      "properties": {
        "primary_key": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "columns": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string"}}
      }
    }
  }
}
