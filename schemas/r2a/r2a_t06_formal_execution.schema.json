{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "r2a_t06_formal_execution.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema", "task_id", "stage_id", "formal_scope_id", "status",
    "approved_implementation_sha", "owner_implementation_review_status",
    "formal_execution_candidate_sha", "formal_execution_candidate_status",
    "owner_formal_execution_review_status",
    "previous_unapproved_formal_execution_sha",
    "successor_formal_execution_candidate_sha", "approved_formal_execution_sha",
    "owner_formal_execution_review_required", "reviewed_formal_execution_sha",
    "formal_run_allowed", "formal_run_executed", "real_score_data_read",
    "formal_artifacts_generated", "authoritative_manifest_generated",
    "formal_authorization_created", "selected_exit_confirmation_m",
    "winner_selected", "q_selection_status", "canonical_dynamic_request_selected",
    "R2A-T06_DONE", "R2A-T07_allowed_to_start", "R3_allowed_to_start",
    "PR_state", "execution_plan", "run_root_policy", "formal_attempt_limit",
    "formal_attempts_consumed", "attempt_marker_policy",
    "repository_local_data_root", "score_release",
    "accepted_handoffs", "protocol_identity", "evaluator_identity", "requests",
    "accepted_counts", "accepted_coverage", "forbidden_input_fields", "scientific_package_files",
    "control_files", "selection_principle", "minimum_sufficient_complexity_rule"
  ],
  "properties": {
    "$schema": {"const": "../../schemas/r2a/r2a_t06_formal_execution.schema.json"},
    "task_id": {"const": "R2A-T06"},
    "stage_id": {"const": "R2A"},
    "formal_scope_id": {"const": "r2a_t06_consecutive_failure_exit_formal_execution.v1"},
    "status": {"const": "formal_execution_candidate_pending_owner_review"},
    "approved_implementation_sha": {"const": "2710d282fadcb998b80b9a482a5d55a4facc775a"},
    "owner_implementation_review_status": {"const": "passed"},
    "formal_execution_candidate_sha": {"const": null},
    "formal_execution_candidate_status": {"const": "pending_owner_review"},
    "owner_formal_execution_review_status": {"const": "pending_successor_review"},
    "previous_unapproved_formal_execution_sha": {"const": "4ebadc8aea216730cc6eb9c8b0b8c911574e488d"},
    "successor_formal_execution_candidate_sha": {"const": null},
    "approved_formal_execution_sha": {"const": "absent"},
    "owner_formal_execution_review_required": {"const": true},
    "reviewed_formal_execution_sha": {"const": null},
    "formal_run_allowed": {"const": false},
    "formal_run_executed": {"const": false},
    "real_score_data_read": {"const": false},
    "formal_artifacts_generated": {"const": false},
    "authoritative_manifest_generated": {"const": false},
    "formal_authorization_created": {"const": false},
    "selected_exit_confirmation_m": {"const": null},
    "winner_selected": {"const": false},
    "q_selection_status": {"const": "not_selected"},
    "canonical_dynamic_request_selected": {"const": false},
    "R2A-T06_DONE": {"const": "absent"},
    "R2A-T07_allowed_to_start": {"const": false},
    "R3_allowed_to_start": {"const": false},
    "PR_state": {"const": "Draft"},
    "execution_plan": {
      "const": {
        "request_order": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"],
        "request_concurrency": 1,
        "evaluation_count_per_request": 1,
        "m_candidate_order": [1, 2, 3],
        "canonical_worker_count": 1,
        "parallel_check_worker_count": 4,
        "determinism_build_count": 2,
        "reuse_daily_facts_across_m": true
      }
    },
    "run_root_policy": {
      "type": "object", "additionalProperties": false,
      "required": ["parent_relative_path", "run_id_format", "require_unique", "allow_resume", "allow_overwrite", "allow_partial_promotion"],
      "properties": {
        "parent_relative_path": {"const": "data/generated/r2a/r2a_t06/formal-runs"},
        "run_id_format": {"const": "R2A-T06-<UTC_TIMESTAMP>"},
        "require_unique": {"const": true}, "allow_resume": {"const": false},
        "allow_overwrite": {"const": false}, "allow_partial_promotion": {"const": false}
      }
    },
    "formal_attempt_limit": {"const": 1},
    "formal_attempts_consumed": {"const": 0},
    "attempt_marker_policy": {
      "const": {
        "relative_path_template": "data/generated/r2a/r2a_t06/formal-runs/<RUN_ID>.attempt-consumed.json",
        "exclusive_create": true,
        "delete_after_failure": false,
        "delete_after_completion": false,
        "attempt_number": 1,
        "initial_status": "consumed"
      }
    },
    "repository_local_data_root": {"const": "data"},
    "score_release": {"$ref": "#/$defs/scoreRelease"},
    "accepted_handoffs": {
      "type": "object", "additionalProperties": false,
      "required": ["t01", "t02", "t03", "t04", "t05", "t05_done", "t05_result_package"],
      "properties": {
        "t01": {"$ref": "#/$defs/fileIdentity"}, "t02": {"$ref": "#/$defs/fileIdentity"},
        "t03": {"$ref": "#/$defs/fileIdentity"}, "t04": {"$ref": "#/$defs/fileIdentity"},
        "t05": {"$ref": "#/$defs/fileIdentity"}, "t05_done": {"$ref": "#/$defs/fileIdentity"},
        "t05_result_package": {"$ref": "#/$defs/fileIdentity"}
      }
    },
    "protocol_identity": {"const": {"dynamic_protocol_version": "pcavt_dynamic_state_protocol.v1", "protocol_config_version": "r2a_t02_dynamic_state_protocol.v1"}},
    "evaluator_identity": {"const": {"evaluator_version": "r2a_t03_dynamic_evaluator.v1", "output_schema_version": "r2a_t03_dynamic_evaluation_output.v1", "bulk_copy_required": true}},
    "requests": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"$ref": "#/$defs/request"}
    },
    "accepted_counts": {"$ref": "#/$defs/acceptedCounts"},
    "accepted_coverage": {"const": {"spine_row_count": 1751066, "source": "R2A-T05 accepted full-scope T03 validation metadata"}},
    "forbidden_input_fields": {"type": "array", "minItems": 10, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "scientific_package_files": {"const": ["request_identity.json", "input_manifest.json", "run_summary.json", "validation_receipt.json", "result_analysis.md", "false_run_length_profile.csv", "recovery_hazard_profile.csv", "candidate_exit_summary.csv", "recognition_lag_profile.csv", "post_recognition_reentry.csv", "episode_fragmentation_profile.csv", "exit_type_margin_profile.csv", "cross_q_nesting_validation.csv", "year_profile.csv", "security_profile.csv", "deterministic_episode_samples.csv", "t06_detail.duckdb"]},
    "control_files": {"const": ["formal_authorization.json", "execution_log.jsonl", "artifact_manifest.json", "result_package.json", "anomaly_scan.json", "determinism_receipt.json"]},
    "selection_principle": {"const": "minimum_sufficient_complexity"},
    "minimum_sufficient_complexity_rule": {"type": "array", "minItems": 5, "maxItems": 5, "items": {"type": "string", "minLength": 1}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "relativePath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.\\.(?:/|$))(?!.*\\\\)"},
    "fileIdentity": {
      "type": "object", "additionalProperties": false,
      "required": ["relative_path", "sha256", "byte_size"],
      "properties": {"relative_path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"}, "byte_size": {"type": "integer", "minimum": 1}}
    },
    "scoreRelease": {
      "type": "object", "additionalProperties": false,
      "required": ["score_release_id", "relative_path", "sha256", "byte_size", "schema_version", "date_min", "date_max", "security_count"],
      "properties": {
        "score_release_id": {"const": "pcavt-score-w120-v1-c7e04f11a2cd09aa"},
        "relative_path": {"$ref": "#/$defs/relativePath"}, "sha256": {"$ref": "#/$defs/sha256"},
        "byte_size": {"type": "integer", "minimum": 1}, "schema_version": {"type": "string"},
        "date_min": {"type": "string", "format": "date"}, "date_max": {"type": "string", "format": "date"},
        "security_count": {"const": 800}
      }
    },
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["logical_request_name", "request_id", "request_hash", "selected_dimensions", "q_by_dimension", "confirmation_k", "selection_status"],
      "properties": {
        "logical_request_name": {"enum": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"]},
        "request_id": {"pattern": "^pcavt-dynreq-v1-[0-9a-f]{16}$"}, "request_hash": {"$ref": "#/$defs/sha256"},
        "selected_dimensions": {"const": ["C", "A"]},
        "q_by_dimension": {"type": "object", "additionalProperties": false, "required": ["C", "A"], "properties": {"C": {"enum": [1000, 1500, 2000, 2500]}, "A": {"enum": [1000, 1500, 2000, 2500]}}},
        "confirmation_k": {"const": 5}, "selection_status": {"const": "evaluated_not_selected"}
      }
    },
    "counts": {
      "type": "object", "additionalProperties": false,
      "required": ["raw_true", "confirmed_true", "intervals", "securities_with_interval"],
      "properties": {"raw_true": {"type": "integer", "minimum": 0}, "confirmed_true": {"type": "integer", "minimum": 0}, "intervals": {"type": "integer", "minimum": 0}, "securities_with_interval": {"type": "integer", "minimum": 0}}
    },
    "acceptedCounts": {
      "type": "object", "additionalProperties": false,
      "required": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"],
      "properties": {"CA_q10_k5": {"$ref": "#/$defs/counts"}, "CA_q15_k5": {"$ref": "#/$defs/counts"}, "CA_q20_k5": {"$ref": "#/$defs/counts"}, "CA_q25_k5": {"$ref": "#/$defs/counts"}}
    }
  }
}
