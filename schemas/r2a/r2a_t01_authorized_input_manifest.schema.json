{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/r2a/r2a_t01_authorized_input_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "manifest_type", "run_id", "synthetic_only", "created_at", "inputs"],
  "properties": {
    "manifest_version": {"const": "r2a_t01_authorized_input_manifest.v1"},
    "manifest_type": {"enum": ["r2a_t01_synthetic_authorized_input", "r2a_t01_formal_authorized_input"]},
    "run_id": {"type": "string", "minLength": 1},
    "synthetic_only": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "formal_authorization_id": {"type": "string", "minLength": 1},
    "inputs": {"type": "object"}
  },
  "oneOf": [
    {
      "properties": {
        "synthetic_only": {"const": true},
        "manifest_type": {"const": "r2a_t01_synthetic_authorized_input"},
        "inputs": {"$ref": "#/$defs/synthetic_inputs"}
      }
    },
    {
      "required": ["source_commit", "formal_authorization_id"],
      "properties": {
        "synthetic_only": {"const": false},
        "manifest_type": {"const": "r2a_t01_formal_authorized_input"},
        "inputs": {"$ref": "#/$defs/formal_inputs"}
      }
    }
  ],
  "$defs": {
    "synthetic_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["securities", "trading_sessions", "security_observation_spine", "pcvt_component_scores", "pcvt_dimension_scores", "a_raw_observations"],
      "properties": {
        "securities": {"$ref": "#/$defs/input"},
        "trading_sessions": {"$ref": "#/$defs/input"},
        "security_observation_spine": {"$ref": "#/$defs/input"},
        "pcvt_component_scores": {"$ref": "#/$defs/input"},
        "pcvt_dimension_scores": {"$ref": "#/$defs/input"},
        "a_raw_observations": {"$ref": "#/$defs/input"}
      }
    },
    "formal_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["securities", "trading_sessions", "security_observation_spine", "pcvt_component_scores", "pcvt_dimension_scores", "a_raw_observations"],
      "properties": {
        "securities": {"$ref": "#/$defs/formal_input"},
        "trading_sessions": {"$ref": "#/$defs/formal_input"},
        "security_observation_spine": {"$ref": "#/$defs/formal_input"},
        "pcvt_component_scores": {"$ref": "#/$defs/formal_input"},
        "pcvt_dimension_scores": {"$ref": "#/$defs/formal_input"},
        "a_raw_observations": {"$ref": "#/$defs/formal_input"}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byte_size"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "byte_size": {"type": "integer", "minimum": 2}
      }
    },
    "formal_input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "byte_size", "source_artifact_id", "source_manifest_sha256", "source_acceptance_status"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "byte_size": {"type": "integer", "minimum": 2},
        "source_artifact_id": {"type": "string", "minLength": 1},
        "source_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "source_acceptance_status": {"const": "accepted"}
      }
    }
  }
}
