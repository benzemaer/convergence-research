{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/r2a/r2a_t01_score_release_manifest.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["manifest_version", "run_id", "score_release_id", "score_release_preimage_sha256", "synthetic_only", "created_at", "authorized_input_manifest_sha256", "formal_authorization_id", "input_summary", "score_data_sha256", "database_byte_size", "schema_sha256", "config_sha256", "availability_policy_id", "availability_policy_version", "availability_policy_sha256", "timezone", "market_information_cutoff", "execution_commit", "environment_lock_sha256", "formal_source_bindings", "worker_count", "row_counts", "coverage", "table_semantic_fingerprints", "registry_fingerprints"],
  "properties": {
    "manifest_version": {"const": "r2a_t01_score_release_manifest.v1"},
    "run_id": {"type": "string", "minLength": 1},
    "score_release_id": {"type": "string", "pattern": "^pcavt-score-w120-v1-[0-9a-f]{16}$"},
    "score_release_preimage_sha256": {"$ref": "#/$defs/hash"},
    "synthetic_only": {"type": "boolean"},
    "created_at": {"type": "string", "format": "date-time"},
    "authorized_input_manifest_sha256": {"$ref": "#/$defs/hash"},
    "formal_authorization_id": {"type": ["string", "null"], "minLength": 1},
    "input_summary": {"$ref": "#/$defs/input_summary"},
    "score_data_sha256": {"$ref": "#/$defs/hash"},
    "database_byte_size": {"type": "integer", "minimum": 1},
    "schema_sha256": {"$ref": "#/$defs/hash"},
    "config_sha256": {"$ref": "#/$defs/hash"},
    "availability_policy_id": {"const": "r2a_t01_eod_close_1500_asia_shanghai.v1"},
    "availability_policy_version": {"const": "1.0.0"},
    "availability_policy_sha256": {"$ref": "#/$defs/hash"},
    "timezone": {"const": "Asia/Shanghai"},
    "market_information_cutoff": {"const": "15:00:00"},
    "execution_commit": {"type": ["string", "null"], "pattern": "^[0-9a-f]{40}$"},
    "environment_lock_sha256": {"$ref": "#/$defs/hash"},
    "formal_source_bindings": {"type": "object", "additionalProperties": {"$ref": "#/$defs/binding"}},
    "worker_count": {"type": "integer", "minimum": 1},
    "row_counts": {"$ref": "#/$defs/table_counts"},
    "coverage": {"type": "object", "additionalProperties": false, "required": ["securities", "trading_sessions", "security_observation_spine", "dimension_definitions", "dimension_components", "daily_component_scores", "daily_dimension_scores"], "properties": {"securities": {"$ref": "#/$defs/coverage"}, "trading_sessions": {"$ref": "#/$defs/coverage"}, "security_observation_spine": {"$ref": "#/$defs/coverage"}, "dimension_definitions": {"$ref": "#/$defs/coverage"}, "dimension_components": {"$ref": "#/$defs/coverage"}, "daily_component_scores": {"$ref": "#/$defs/coverage"}, "daily_dimension_scores": {"$ref": "#/$defs/coverage"}}},
    "table_semantic_fingerprints": {"type": "object", "minProperties": 7, "additionalProperties": {"$ref": "#/$defs/fingerprint"}},
    "registry_fingerprints": {"type": "object", "additionalProperties": false, "required": ["dimension_definitions", "dimension_components"], "properties": {"dimension_definitions": {"$ref": "#/$defs/hash"}, "dimension_components": {"$ref": "#/$defs/hash"}}}
  },
  "allOf": [
    {"if": {"properties": {"synthetic_only": {"const": true}}}, "then": {"properties": {"formal_authorization_id": {"const": null}, "execution_commit": {"const": null}, "formal_source_bindings": {"maxProperties": 0}}}, "else": {"properties": {"formal_authorization_id": {"type": "string", "minLength": 1}}}}
  ],
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "input_summary": {"oneOf": [{"$ref": "#/$defs/synthetic_input_summary_set"}, {"$ref": "#/$defs/formal_input_summary_set"}]},
    "synthetic_input_summary_set": {"type": "object", "additionalProperties": false, "required": ["securities", "trading_sessions", "security_observation_spine", "pcvt_component_scores", "pcvt_dimension_scores", "a_raw_observations", "pcvt_validation_raw"], "properties": {"securities": {"$ref": "#/$defs/synthetic_input_summary"}, "trading_sessions": {"$ref": "#/$defs/synthetic_input_summary"}, "security_observation_spine": {"$ref": "#/$defs/synthetic_input_summary"}, "pcvt_component_scores": {"$ref": "#/$defs/synthetic_input_summary"}, "pcvt_dimension_scores": {"$ref": "#/$defs/synthetic_input_summary"}, "a_raw_observations": {"$ref": "#/$defs/synthetic_input_summary"}, "pcvt_validation_raw": {"$ref": "#/$defs/synthetic_input_summary"}}},
    "formal_input_summary_set": {"type": "object", "additionalProperties": false, "required": ["security_observation_spine", "pcvt_component_scores", "pcvt_dimension_scores", "a_raw_observations", "pcvt_validation_raw"], "properties": {"security_observation_spine": {"$ref": "#/$defs/formal_input_summary"}, "pcvt_component_scores": {"$ref": "#/$defs/formal_input_summary"}, "pcvt_dimension_scores": {"$ref": "#/$defs/formal_input_summary"}, "a_raw_observations": {"$ref": "#/$defs/formal_input_summary"}, "pcvt_validation_raw": {"$ref": "#/$defs/formal_input_summary"}}},
    "input_summary_entry": {"oneOf": [{"$ref": "#/$defs/synthetic_input_summary"}, {"$ref": "#/$defs/formal_input_summary"}]},
    "synthetic_input_summary": {"type": "object", "additionalProperties": false, "required": ["sha256", "byte_size", "input_role"], "properties": {"sha256": {"$ref": "#/$defs/hash"}, "byte_size": {"type": "integer", "minimum": 1}, "input_role": {"enum": ["materialization", "validation_only"]}}},
    "formal_input_summary": {"type": "object", "additionalProperties": false, "required": ["sha256", "byte_size", "logical_table_name", "row_count", "security_count", "date_min", "date_max", "schema_identity", "source_artifact_id", "source_manifest_sha256", "source_acceptance_status", "source_run_id", "source_contract_id", "input_role"], "properties": {"sha256": {"$ref": "#/$defs/hash"}, "byte_size": {"type": "integer", "minimum": 1}, "logical_table_name": {"type": "string", "minLength": 1}, "row_count": {"type": "integer", "minimum": 0}, "security_count": {"type": "integer", "minimum": 0}, "date_min": {"type": ["string", "null"], "format": "date"}, "date_max": {"type": ["string", "null"], "format": "date"}, "schema_identity": {"$ref": "#/$defs/hash"}, "source_artifact_id": {"type": "string", "minLength": 1}, "source_manifest_sha256": {"$ref": "#/$defs/hash"}, "source_acceptance_status": {"const": "accepted"}, "source_run_id": {"type": "string", "minLength": 1}, "source_contract_id": {"type": "string", "minLength": 1}, "input_role": {"enum": ["materialization", "validation_only"]}}},
    "coverage": {"type": "object", "additionalProperties": false, "required": ["security_count", "date_min", "date_max"], "properties": {"security_count": {"type": "integer", "minimum": 0}, "date_min": {"type": ["string", "null"], "format": "date"}, "date_max": {"type": ["string", "null"], "format": "date"}}},
    "fingerprint": {"type": "object", "additionalProperties": false, "required": ["row_count", "xor_hash", "sum_hash"], "properties": {"row_count": {"type": "integer", "minimum": 0}, "xor_hash": {"type": "string"}, "sum_hash": {"type": "string"}}},
    "table_counts": {"type": "object", "additionalProperties": false, "required": ["securities", "trading_sessions", "security_observation_spine", "dimension_definitions", "dimension_components", "daily_component_scores", "daily_dimension_scores"], "properties": {"securities": {"type": "integer", "minimum": 1}, "trading_sessions": {"type": "integer", "minimum": 1}, "security_observation_spine": {"type": "integer", "minimum": 1}, "dimension_definitions": {"const": 5}, "dimension_components": {"const": 10}, "daily_component_scores": {"type": "integer", "minimum": 10}, "daily_dimension_scores": {"type": "integer", "minimum": 5}}},
    "binding": {"type": "object", "additionalProperties": true, "required": ["path", "source_commit", "git_blob_sha", "committed_byte_sha256", "normalized_text_sha256", "encoding", "line_ending", "bom", "terminal_lf_count"], "properties": {"path": {"type": "string", "minLength": 1}, "source_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "git_blob_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"}, "committed_byte_sha256": {"$ref": "#/$defs/hash"}, "normalized_text_sha256": {"$ref": "#/$defs/hash"}, "encoding": {"const": "utf-8"}, "line_ending": {"const": "lf"}, "bom": {"const": false}, "terminal_lf_count": {"const": 1}}}
  }
}
