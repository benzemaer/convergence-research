{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/r2a/r2a_t05_ca_exit_decomposition.schema.json",
  "title": "R2A-T05 CA exit mechanism decomposition implementation contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema", "task_id", "stage_id", "status", "scope_id", "implementation_version",
    "research_anchor_q", "research_anchor_role", "q_selection_status",
    "canonical_dynamic_request_selected", "formal_run_allowed", "formal_run_started",
    "real_score_data_read", "formal_artifacts_generated", "R2A-T05_DONE",
    "R2A-T06_started", "R2A-T06_allowed_to_start", "PR_state", "accepted_bindings",
    "requests", "accepted_t04_counts", "input_contract", "termination_definition",
    "threshold_margin_definition", "quick_reentry_definition", "cross_q_definition",
    "result_package", "t06_boundary", "non_goals"
  ],
  "properties": {
    "$schema": {"const": "../../schemas/r2a/r2a_t05_ca_exit_decomposition.schema.json"},
    "task_id": {"const": "R2A-T05"},
    "stage_id": {"const": "R2A"},
    "status": {"const": "implementation_candidate_pending_owner_review"},
    "scope_id": {"const": "r2a_t05_ca_exit_mechanism_decomposition.v1"},
    "implementation_version": {"const": "r2a_t05_ca_exit_decomposition.v1"},
    "research_anchor_q": {"const": 2000},
    "research_anchor_role": {"const": "exit_mechanism_decomposition"},
    "q_selection_status": {"const": "not_selected"},
    "canonical_dynamic_request_selected": {"const": false},
    "formal_run_allowed": {"const": false},
    "formal_run_started": {"const": false},
    "real_score_data_read": {"const": false},
    "formal_artifacts_generated": {"const": false},
    "R2A-T05_DONE": {"const": "absent"},
    "R2A-T06_started": {"const": false},
    "R2A-T06_allowed_to_start": {"const": false},
    "PR_state": {"const": "Draft"},
    "accepted_bindings": {
      "type": "object", "additionalProperties": false,
      "required": ["score_release", "evaluator", "t04_handoff"],
      "properties": {
        "score_release": {
          "type": "object", "additionalProperties": false,
          "required": ["score_release_id", "sha256", "byte_size", "accepted_t01_handoff_sha256"],
          "properties": {
            "score_release_id": {"const": "pcavt-score-w120-v1-c7e04f11a2cd09aa"},
            "sha256": {"$ref": "#/$defs/sha256"},
            "byte_size": {"type": "integer", "minimum": 1},
            "accepted_t01_handoff_sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "evaluator": {
          "type": "object", "additionalProperties": false,
          "required": ["evaluator_version", "output_schema_version", "dynamic_protocol_version", "accepted_t03_handoff_sha256", "accepted_t03_config_sha256"],
          "properties": {
            "evaluator_version": {"const": "r2a_t03_dynamic_evaluator.v1"},
            "output_schema_version": {"const": "r2a_t03_dynamic_evaluation_output.v1"},
            "dynamic_protocol_version": {"const": "pcavt_dynamic_state_protocol.v1"},
            "accepted_t03_handoff_sha256": {"$ref": "#/$defs/sha256"},
            "accepted_t03_config_sha256": {"$ref": "#/$defs/sha256"}
          }
        },
        "t04_handoff": {
          "type": "object", "additionalProperties": false,
          "required": ["relative_path", "sha256", "scope_id", "panel_id", "accepted_run_id"],
          "properties": {
            "relative_path": {"const": "data/generated/r2a/r2a_t04/R2A-T04-20260720T002158508Z/r2a_t04_accepted_result_handoff.json"},
            "sha256": {"$ref": "#/$defs/sha256"},
            "scope_id": {"const": "r2a_t04_ca_q10_q15_q20_q25_k5_response_audit.v1"},
            "panel_id": {"const": "r2a_t04_ca_four_q_k5_panel.v1"},
            "accepted_run_id": {"const": "R2A-T04-20260720T002158508Z"}
          }
        }
      }
    },
    "requests": {
      "type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true,
      "items": {"$ref": "#/$defs/request"}
    },
    "accepted_t04_counts": {
      "type": "object", "additionalProperties": false,
      "required": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"],
      "properties": {
        "CA_q10_k5": {"const": {"raw_true": 20559, "confirmed_true": 1916, "intervals": 751, "securities_with_interval": 473}},
        "CA_q15_k5": {"const": {"raw_true": 46651, "confirmed_true": 7125, "intervals": 2426, "securities_with_interval": 734}},
        "CA_q20_k5": {"const": {"raw_true": 81535, "confirmed_true": 17642, "intervals": 5372, "securities_with_interval": 775}},
        "CA_q25_k5": {"const": {"raw_true": 124893, "confirmed_true": 35098, "intervals": 9107, "securities_with_interval": 788}}
      }
    },
    "input_contract": {"$ref": "#/$defs/input_contract"},
    "termination_definition": {"$ref": "#/$defs/termination_definition"},
    "threshold_margin_definition": {"$ref": "#/$defs/threshold_margin_definition"},
    "quick_reentry_definition": {"$ref": "#/$defs/quick_reentry_definition"},
    "cross_q_definition": {"$ref": "#/$defs/cross_q_definition"},
    "result_package": {"$ref": "#/$defs/result_package"},
    "t06_boundary": {"$ref": "#/$defs/t06_boundary"},
    "non_goals": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["logical_request_name", "request_id", "request_hash", "selected_dimensions", "q_by_dimension", "confirmation_k", "selection_status", "comparison_role"],
      "properties": {
        "logical_request_name": {"enum": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"]},
        "request_id": {"type": "string", "pattern": "^pcavt-dynreq-v1-[0-9a-f]{16}$"},
        "request_hash": {"$ref": "#/$defs/sha256"},
        "selected_dimensions": {"const": ["C", "A"]},
        "q_by_dimension": {
          "type": "object", "additionalProperties": false,
          "required": ["C", "A"],
          "properties": {"C": {"enum": [1000, 1500, 2000, 2500]}, "A": {"enum": [1000, 1500, 2000, 2500]}}
        },
        "confirmation_k": {"const": 5},
        "selection_status": {"const": "evaluated_not_selected"},
        "comparison_role": {"enum": ["cross_q_structure_comparison", "research_anchor_exit_mechanism_decomposition"]}
      }
    },
    "input_contract": {
      "type": "object", "additionalProperties": false,
      "required": [
        "formal_allowed_sources", "candidate_source_mode", "allowed_score_tables",
        "allowed_evaluator_tables", "requires_observation_sequence", "requires_same_q_follow_up",
        "future_path_and_transaction_data_allowed", "price_and_return_data_allowed",
        "formal_run_reads_real_score"
      ],
      "properties": {
        "formal_allowed_sources": {"const": [
          "accepted R2A-T01 canonical Score release",
          "accepted R2A-T03 evaluator and output protocol identity",
          "accepted R2A-T04 handoff, request identities and accepted count facts",
          "repository-local data/**"
        ]},
        "candidate_source_mode": {"const": "synthetic_fixture_only"},
        "allowed_score_tables": {"const": [
          "securities", "trading_sessions", "security_observation_spine",
          "dimension_definitions", "dimension_components", "daily_component_scores",
          "daily_dimension_scores"
        ]},
        "allowed_evaluator_tables": {"const": [
          "dynamic_request", "evaluation_scope", "daily_dimension_states",
          "daily_joint_states", "confirmed_intervals"
        ]},
        "requires_observation_sequence": {"const": true},
        "requires_same_q_follow_up": {"const": true},
        "future_path_and_transaction_data_allowed": {"const": false},
        "price_and_return_data_allowed": {"const": false},
        "formal_run_reads_real_score": {"const": false}
      }
    },
    "termination_definition": {
      "type": "object", "additionalProperties": false,
      "required": [
        "interval_unit", "interval_semantics_modified", "termination_rule_modified",
        "primary_categories", "quality_primary_reasons", "raw_false_subclasses",
        "raw_false_unclassified_allowed", "unsupported_changes"
      ],
      "properties": {
        "interval_unit": {"const": "accepted_v1_confirmed_interval"},
        "interval_semantics_modified": {"const": false},
        "termination_rule_modified": {"const": false},
        "primary_categories": {"const": [
          "raw_false", "quality_or_availability_termination", "input_end_open_right_censored"
        ]},
        "quality_primary_reasons": {"const": [
          "expected_observation_missing", "expected_observation_listing_pause",
          "selected_dimension_blocked", "selected_dimension_diagnostic_required",
          "selected_dimension_unknown", "selected_dimension_not_eligible",
          "selected_dimension_score_non_finite"
        ]},
        "raw_false_subclasses": {"const": ["A_ONLY_FAIL", "C_ONLY_FAIL", "CA_BOTH_FAIL"]},
        "raw_false_unclassified_allowed": {"const": false},
        "unsupported_changes": {"const": ["d", "g", "exit_delay", "hysteresis", "gap_tolerance", "interval_merge"]}
      }
    },
    "threshold_margin_definition": {
      "type": "object", "additionalProperties": false,
      "required": [
        "q_by_dimension", "main_threshold", "weak_threshold", "mean_margin", "min_margin",
        "active_margin", "epsilon", "gate_failure_classes", "signed_margin_preserved",
        "component_scores_retained"
      ],
      "properties": {
        "q_by_dimension": {"const": "request_q_bp / 10000"},
        "main_threshold": {"const": "1 - q_D"},
        "weak_threshold": {"const": "1 - q_D - 0.10"},
        "mean_margin": {"const": "score_dimension_D - main_threshold_D"},
        "min_margin": {"const": "score_dimension_min_D - weak_threshold_D"},
        "active_margin": {"const": "min(mean_margin_D, min_margin_D)"},
        "epsilon": {"const": 1e-12},
        "gate_failure_classes": {"const": ["MAIN_ONLY_FAIL", "WEAK_ONLY_FAIL", "MAIN_AND_WEAK_FAIL", "NO_GATE_FAIL", "NOT_EVALUABLE"]},
        "signed_margin_preserved": {"const": true},
        "component_scores_retained": {"const": true}
      }
    },
    "quick_reentry_definition": {
      "type": "object", "additionalProperties": false,
      "required": [
        "sequence_field", "calendar_difference_allowed", "raw_true_max_lag", "confirmed_true_max_lag",
        "raw_rates", "confirmed_rates", "no_reentry_statuses", "accepted_interval_mutation_allowed"
      ],
      "properties": {
        "sequence_field": {"const": "observation_sequence"},
        "calendar_difference_allowed": {"const": false},
        "raw_true_max_lag": {"const": 5},
        "confirmed_true_max_lag": {"const": 10},
        "raw_rates": {"const": [1, 3, 5]},
        "confirmed_rates": {"const": [5, 10]},
        "no_reentry_statuses": {"const": ["not_reentered_within_window", "insufficient_followup_censored", "quality_interrupted"]},
        "accepted_interval_mutation_allowed": {"const": false}
      }
    },
    "cross_q_definition": {
      "type": "object", "additionalProperties": false,
      "required": [
        "confirmed_nested_order", "mapping_rule", "nearest_date_matching_allowed", "calendar_tolerance_allowed",
        "daily_identities", "identity_exhaustive_over", "q20_sibling_count_excludes_self"
      ],
      "properties": {
        "confirmed_nested_order": {"const": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"]},
        "mapping_rule": {"const": "all_child_confirmed_observation_keys_must_be_uniquely_contained_in_one_parent_interval"},
        "nearest_date_matching_allowed": {"const": false},
        "calendar_tolerance_allowed": {"const": false},
        "daily_identities": {"const": ["Q10_CORE", "Q15_NOT_Q10_CORE", "Q20_NOT_Q15_ANCHOR", "Q25_NOT_Q20_SHELL"]},
        "identity_exhaustive_over": {"const": "q25_parent_confirmed_days"},
        "q20_sibling_count_excludes_self": {"const": true}
      }
    },
    "result_package": {
      "type": "object", "additionalProperties": false,
      "required": ["schema_version", "required_files", "large_detail_storage", "formal_artifacts_generated_in_this_pr"],
      "properties": {
        "schema_version": {"const": "r2a_t05_result_package.v1"},
        "required_files": {"const": [
          "request_identity.json", "input_manifest.json", "run_summary.json", "validation_receipt.json",
          "result_analysis.md", "request_reconciliation.csv", "termination_reason_profile.csv",
          "raw_false_exit_decomposition.csv", "threshold_margin_summary.csv", "quick_reentry_profile.csv",
          "cross_q_structure_summary.csv", "year_profile.csv", "security_profile.csv",
          "deterministic_interval_samples.csv"
        ]},
        "large_detail_storage": {"const": ["repository-local git-ignored DuckDB", "repository-local git-ignored Parquet"]},
        "formal_artifacts_generated_in_this_pr": {"const": false}
      }
    },
    "t06_boundary": {
      "type": "object", "additionalProperties": false,
      "required": [
        "research_goal", "inputs", "outputs", "current_pr_implements", "current_pr_creates_config",
        "current_pr_reads_price_data", "mandatory_acceptance_requirements"
      ],
      "properties": {
        "research_goal": {"const": "read point-in-time observation data to freeze release onset, recognition, direction and intensity labels"},
        "inputs": {"const": ["accepted Score release", "point-in-time availability metadata", "future observation protocol"]},
        "outputs": {"const": ["release onset label", "release recognition label", "direction label", "intensity label"]},
        "current_pr_implements": {"const": false},
        "current_pr_creates_config": {"const": false},
        "current_pr_reads_price_data": {"const": false},
        "mandatory_acceptance_requirements": {"const": ["no-lookahead", "point-in-time availability", "replay equals batch", "missing observation is not skipped"]}
      }
    }
  }
}
