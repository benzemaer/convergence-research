{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/r2a/r2a_t05_formal_execution.schema.json",
  "title": "R2A-T05 formal execution candidate contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "task_id",
    "stage_id",
    "status",
    "formal_scope_id",
    "implementation_version",
    "reviewed_implementation_sha",
    "implementation_review_status",
    "superseded_formal_execution_candidate_sha",
    "formal_execution_review_status",
    "research_anchor_q",
    "q_selection_status",
    "canonical_dynamic_request_selected",
    "formal_run_allowed",
    "formal_run_started",
    "real_score_data_read",
    "formal_artifacts_generated",
    "R2A-T05_DONE",
    "R2A-T06_allowed_to_start",
    "PR_state",
    "formal_run_attempt_limit",
    "formal_run_attempts_consumed",
    "run_root_policy",
    "input_authorization",
    "authorization_metadata",
    "accepted_bindings",
    "request_order",
    "request_sources",
    "requests",
    "accepted_t04_counts",
    "accepted_t03_output_contract",
    "protected_implementation_files",
    "protected_execution_files",
    "artifact_plan",
    "lifecycle_after_completion",
    "result_analysis_requirements",
    "non_goals"
  ],
  "properties": {
    "$schema": {"const": "../../schemas/r2a/r2a_t05_formal_execution.schema.json"},
    "task_id": {"const": "R2A-T05"},
    "stage_id": {"const": "R2A"},
    "status": {"const": "formal_execution_candidate_pending_owner_review"},
    "formal_scope_id": {"const": "r2a_t05_ca_exit_mechanism_formal_execution.v1"},
    "implementation_version": {"const": "r2a_t05_ca_exit_decomposition.v1"},
    "reviewed_implementation_sha": {"const": "55dceba70bc967caa75c597ce17acb93a2dac511"},
    "implementation_review_status": {"const": "approved"},
    "superseded_formal_execution_candidate_sha": {"const": "0b7ef1a4e64cc760b248916c13aa89cb9f7a2530"},
    "formal_execution_review_status": {"const": "pending_owner_rereview"},
    "research_anchor_q": {"const": 2000},
    "q_selection_status": {"const": "not_selected"},
    "canonical_dynamic_request_selected": {"const": false},
    "formal_run_allowed": {"const": false},
    "formal_run_started": {"const": false},
    "real_score_data_read": {"const": false},
    "formal_artifacts_generated": {"const": false},
    "R2A-T05_DONE": {"const": "absent"},
    "R2A-T06_allowed_to_start": {"const": false},
    "PR_state": {"const": "Draft"},
    "formal_run_attempt_limit": {"const": 2},
    "formal_run_attempts_consumed": {"const": 1},
    "run_root_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parent_relative_path", "run_id_format", "utc_timestamp_required", "require_unique", "allow_resume", "allow_overwrite", "allow_automatic_rerun", "allow_skip", "allow_partial_promotion", "historical_consumed_run_ids", "historical_failed_run_inventory_sha256", "next_attempt_number", "additional_attempts_authorizable", "owner_authorized_retry_required"],
      "properties": {
        "parent_relative_path": {"const": "data/generated/r2a/r2a_t05/formal-runs"},
        "run_id_format": {"const": "R2A-T05-<UTC_TIMESTAMP>"},
        "utc_timestamp_required": {"const": true},
        "require_unique": {"const": true},
        "allow_resume": {"const": false},
        "allow_overwrite": {"const": false},
        "allow_automatic_rerun": {"const": false},
        "allow_skip": {"const": false},
        "allow_partial_promotion": {"const": false},
        "historical_consumed_run_ids": {"const": ["R2A-T05-20260721T013805600Z"]},
        "historical_failed_run_inventory_sha256": {"const": "9baeb8a2f6b2ffb47251d937c1551ff83450f62a49996771528c4b3dcf502770"},
        "next_attempt_number": {"const": 2},
        "additional_attempts_authorizable": {"const": 1},
        "owner_authorized_retry_required": {"const": true}
      }
    },
    "input_authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_repository_roots", "retired_external_root_names", "reject_reparse_points", "reject_compatibility_paths", "score_database_relative_path", "manifest_schema_version", "request_identity_source"],
      "properties": {
        "allowed_repository_roots": {"const": ["data/raw", "data/external", "data/interim", "data/generated"]},
        "retired_external_root_names": {"const": ["convergence-research-inputs"]},
        "reject_reparse_points": {"const": true},
        "reject_compatibility_paths": {"const": true},
        "score_database_relative_path": {"const": "data/generated/r2a/r2a_t01/R2A-T01-20260718T103110891Z/score-release/pcavt-score-w120-v1-c7e04f11a2cd09aa/score_data.duckdb"},
        "manifest_schema_version": {"const": "r2a_t05_formal_input_manifest.v1"},
        "request_identity_source": {"const": "accepted R2A-T04 handoff requests; request files are only independently revalidated envelopes"}
      }
    },
    "authorization_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative_path", "schema_relative_path", "authorization_status", "formal_run_allowed", "authorization_revision"],
      "properties": {
        "relative_path": {"const": "configs/r2a/r2a_t05_formal_authorization.v1.json"},
        "schema_relative_path": {"const": "schemas/r2a/r2a_t05_formal_authorization.schema.json"},
        "authorization_status": {"const": "not_authorized"},
        "formal_run_allowed": {"const": false},
        "authorization_revision": {"const": 0}
      }
    },
    "accepted_bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score_release", "t01_handoff", "t03_handoff", "t03_config", "t04_handoff"],
      "properties": {
        "score_release": {
          "type": "object", "additionalProperties": false,
          "required": ["score_release_id", "relative_path", "sha256", "byte_size", "security_count", "date_min", "date_max", "accepted_t01_handoff_sha256"],
          "properties": {
            "score_release_id": {"const": "pcavt-score-w120-v1-c7e04f11a2cd09aa"},
            "relative_path": {"const": "data/generated/r2a/r2a_t01/R2A-T01-20260718T103110891Z/score-release/pcavt-score-w120-v1-c7e04f11a2cd09aa/score_data.duckdb"},
            "sha256": {"const": "d1ee60ef854a5fe18042c61175febd837db43d76c5c104462ce61c3f176403a3"},
            "byte_size": {"const": 4255395840},
            "security_count": {"const": 800},
            "date_min": {"const": "2016-01-04"},
            "date_max": {"const": "2026-06-30"},
            "accepted_t01_handoff_sha256": {"const": "142fa9f022025c6097a2651013a1434dae2eb153dc42da8d6450523571c192ad"}
          }
        },
        "t01_handoff": {"$ref": "#/$defs/handoff_binding"},
        "t03_handoff": {"$ref": "#/$defs/handoff_binding"},
        "t03_config": {"$ref": "#/$defs/handoff_binding"},
        "t04_handoff": {
          "type": "object", "additionalProperties": false,
          "required": ["relative_path", "sha256", "scope_id", "panel_id", "accepted_run_id"],
          "properties": {
            "relative_path": {"const": "data/generated/r2a/r2a_t04/R2A-T04-20260720T002158508Z/r2a_t04_accepted_result_handoff.json"},
            "sha256": {"const": "ec4aa13d8b428adb03e6f7faff591741f2730c50cdc87d98f33c9e6ef9e20c5a"},
            "scope_id": {"const": "r2a_t04_ca_q10_q15_q20_q25_k5_response_audit.v1"},
            "panel_id": {"const": "r2a_t04_ca_four_q_k5_panel.v1"},
            "accepted_run_id": {"const": "R2A-T04-20260720T002158508Z"}
          }
        }
      }
    },
    "request_order": {"const": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"]},
    "request_sources": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"$ref": "#/$defs/request_source"}
    },
    "requests": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "items": {"$ref": "#/$defs/request"}
    },
    "accepted_t04_counts": {"$ref": "#/$defs/accepted_counts"},
    "accepted_t03_output_contract": {
      "type": "object", "additionalProperties": false,
      "required": ["evaluator_version", "output_schema_version", "dynamic_protocol_version", "input_tables", "output_tables", "validator_function", "fresh_output_required", "serial_request_execution"],
      "properties": {
        "evaluator_version": {"const": "r2a_t03_dynamic_evaluator.v1"},
        "output_schema_version": {"const": "r2a_t03_dynamic_evaluation_output.v1"},
        "dynamic_protocol_version": {"const": "pcavt_dynamic_state_protocol.v1"},
        "input_tables": {"const": ["security_observation_spine", "daily_dimension_scores"]},
        "output_tables": {"const": ["dynamic_request", "evaluation_scope", "daily_dimension_states", "daily_joint_states", "confirmed_intervals"]},
        "validator_function": {"const": "src.r2a.r2a_t03_output_contract.validate_dynamic_evaluation_output"},
        "fresh_output_required": {"const": true},
        "serial_request_execution": {"const": true}
      }
    },
    "protected_implementation_files": {
      "type": "array", "minItems": 9, "maxItems": 9,
      "items": {"$ref": "#/$defs/protected_file"}
    },
    "protected_execution_files": {
      "type": "array", "minItems": 10, "maxItems": 10,
      "items": {"$ref": "#/$defs/protected_file"}
    },
    "artifact_plan": {
      "type": "object", "additionalProperties": false,
      "required": ["detail_relative_files", "compact_review_files", "cross_q_structure_alias", "local_only_detail_allowed"],
      "properties": {
        "detail_relative_files": {"type": "array", "minItems": 10, "items": {"type": "string"}},
        "compact_review_files": {"type": "array", "minItems": 16, "items": {"type": "string"}},
        "cross_q_structure_alias": {
          "type": "object", "additionalProperties": false,
          "required": ["alias_file", "role", "source_file", "no_inconsistent_duplicate"],
          "properties": {
            "alias_file": {"const": "cross_q_structure_summary.csv"},
            "role": {"const": "parent_structure_summary_alias"},
            "source_file": {"const": "cross_q_parent_structure_summary.csv"},
            "no_inconsistent_duplicate": {"const": true}
          }
        },
        "local_only_detail_allowed": {"const": ["daily_level_identities", "cross_q_mapping", "termination_records", "request_results"]}
      }
    },
    "lifecycle_after_completion": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "formal_run_started", "real_score_data_read", "formal_artifacts_generated", "R2A-T05_DONE", "R2A-T06_allowed_to_start"],
      "properties": {
        "status": {"const": "formal_completed_pending_owner_review"},
        "formal_run_started": {"const": true},
        "real_score_data_read": {"const": true},
        "formal_artifacts_generated": {"const": true},
        "R2A-T05_DONE": {"const": "absent"},
        "R2A-T06_allowed_to_start": {"const": false}
      }
    },
    "result_analysis_requirements": {
      "type": "array", "minItems": 10, "items": {"type": "string"}
    },
    "non_goals": {"type": "array", "minItems": 1, "items": {"type": "string"}}
  },
  "$defs": {
    "hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "relative_path": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|/)\\.\\.(?:/|$))(?!.*\\\\)"},
    "handoff_binding": {
      "type": "object", "additionalProperties": false,
      "required": ["relative_path", "sha256"],
      "properties": {"relative_path": {"$ref": "#/$defs/relative_path"}, "sha256": {"$ref": "#/$defs/hash"}}
    },
    "request_source": {
      "type": "object", "additionalProperties": false,
      "required": ["logical_request_name", "relative_path", "sha256", "byte_size"],
      "properties": {
        "logical_request_name": {"enum": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"]},
        "relative_path": {"$ref": "#/$defs/relative_path"},
        "sha256": {"$ref": "#/$defs/hash"},
        "byte_size": {"type": "integer", "minimum": 1}
      }
    },
    "request": {
      "type": "object", "additionalProperties": false,
      "required": ["logical_request_name", "request_id", "request_hash", "selected_dimensions", "q_by_dimension", "confirmation_k", "selection_status", "comparison_role"],
      "properties": {
        "logical_request_name": {"enum": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"]},
        "request_id": {"type": "string", "pattern": "^pcavt-dynreq-v1-[0-9a-f]{16}$"},
        "request_hash": {"$ref": "#/$defs/hash"},
        "selected_dimensions": {"const": ["C", "A"]},
        "q_by_dimension": {"type": "object", "additionalProperties": false, "required": ["C", "A"], "properties": {"C": {"enum": [1000, 1500, 2000, 2500]}, "A": {"enum": [1000, 1500, 2000, 2500]}}},
        "confirmation_k": {"const": 5},
        "selection_status": {"const": "evaluated_not_selected"},
        "comparison_role": {"enum": ["cross_q_structure_comparison", "research_anchor_exit_mechanism_decomposition"]}
      }
    },
    "accepted_counts": {
      "type": "object", "additionalProperties": false,
      "required": ["CA_q10_k5", "CA_q15_k5", "CA_q20_k5", "CA_q25_k5"],
      "properties": {
        "CA_q10_k5": {"const": {"raw_true": 20559, "confirmed_true": 1916, "intervals": 751, "securities_with_interval": 473}},
        "CA_q15_k5": {"const": {"raw_true": 46651, "confirmed_true": 7125, "intervals": 2426, "securities_with_interval": 734}},
        "CA_q20_k5": {"const": {"raw_true": 81535, "confirmed_true": 17642, "intervals": 5372, "securities_with_interval": 775}},
        "CA_q25_k5": {"const": {"raw_true": 124893, "confirmed_true": 35098, "intervals": 9107, "securities_with_interval": 788}}
      }
    },
    "protected_file": {
      "type": "object", "additionalProperties": false,
      "required": ["path", "source_commit", "git_blob_sha", "committed_byte_sha256", "normalized_text_sha256", "encoding", "line_ending", "bom", "trailing_lf_count"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "source_commit": {"$ref": "#/$defs/commit"},
        "git_blob_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "committed_byte_sha256": {"$ref": "#/$defs/hash"},
        "normalized_text_sha256": {"$ref": "#/$defs/hash"},
        "encoding": {"const": "utf-8"},
        "line_ending": {"const": "LF"},
        "bom": {"const": false},
        "trailing_lf_count": {"const": 1}
      }
    }
  }
}
