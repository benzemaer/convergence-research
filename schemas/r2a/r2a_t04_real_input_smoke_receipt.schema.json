    "formal_run_started": {"const": false},
    "formal_run_attempt_consumed": {"const": false},
    "full_universe_request_count": {"const": 0}
  },
  "$defs": {
    "output_counts": {"type": "object", "additionalProperties": false, "properties": {"dynamic_request":{"type":"integer","minimum":0},"evaluation_scope":{"type":"integer","minimum":0},"daily_dimension_states":{"type":"integer","minimum":0},"daily_joint_states":{"type":"integer","minimum":0},"confirmed_intervals":{"type":"integer","minimum":0}}},
    "output_fingerprints": {"type": "object", "additionalProperties": false, "properties": {"dynamic_request":{"type":"string","pattern":"^[0-9a-f]{64}$"},"evaluation_scope":{"type":"string","pattern":"^[0-9a-f]{64}$"},"daily_dimension_states":{"type":"string","pattern":"^[0-9a-f]{64}$"},"daily_joint_states":{"type":"string","pattern":"^[0-9a-f]{64}$"},"confirmed_intervals":{"type":"string","pattern":"^[0-9a-f]{64}$"}}}
