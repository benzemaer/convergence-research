{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/r2a/r2a_t02_dynamic_request_spec.schema.json",
  "title": "R2A-T02 dynamic-state scientific request spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_schema_version",
    "dynamic_protocol_version",
    "score_release_id",
    "selected_dimensions",
    "q_by_dimension",
    "confirmation_k"
  ],
  "properties": {
    "request_schema_version": {"const": "r2a_t02_dynamic_request_spec.v1"},
    "dynamic_protocol_version": {"const": "pcavt_dynamic_state_protocol.v1"},
    "score_release_id": {"const": "pcavt-score-w120-v1-c7e04f11a2cd09aa"},
    "selected_dimensions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "uniqueItems": true,
      "items": {"enum": ["P", "C", "A", "V", "T"]}
    },
    "q_by_dimension": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "maxProperties": 5,
      "properties": {
        "P": {"type": "integer", "enum": [1000, 1500, 2000, 2500]},
        "C": {"type": "integer", "enum": [1000, 1500, 2000, 2500]},
        "A": {"type": "integer", "enum": [1000, 1500, 2000, 2500]},
        "V": {"type": "integer", "enum": [1000, 1500, 2000, 2500]},
        "T": {"type": "integer", "enum": [1000, 1500, 2000, 2500]}
      }
    },
    "confirmation_k": {
      "type": "integer",
      "enum": [2, 3, 4, 5, 6, 7]
    }
  }
}
