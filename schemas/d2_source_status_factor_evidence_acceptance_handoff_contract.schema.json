    "local_candidate_artifact_write_authorized": {"const": true},
    "local_candidate_report_write_authorized": {"const": true},
    "synthetic_test_only": {"const": false},
    "default_output_dir": {"const": "data/generated/d2/d2_t11_source_status_factor_evidence/"},
    "depends_on": {"allOf": [{"$ref": "#/$defs/strings"}, {"contains": {"const": "D2_FORMAL_SOURCE_REGISTRY_CONTRACT_V1"}}, {"contains": {"const": "D2_HITHINK_RAW_OHLCV_PROBE_CONTRACT_V1"}}, {"contains": {"const": "D2_HITHINK_RAW_MARKET_PRICES_CANDIDATE_MATERIALIZATION_CONTRACT_V1"}}, {"contains": {"const": "D2_HITHINK_RAW_MARKET_PRICES_CANDIDATE_ARTIFACT_CONTRACT_V1"}}, {"contains": {"const": "D2_ADJUSTED_PRICE_QUALITY_GAP_CANDIDATE_CONTRACT_V1"}}, {"contains": {"const": "D2_ACCEPTANCE_D3_HANDOFF_CONTRACT_V1"}}, {"contains": {"const": "D2_MARKET_QUALITY_PCVT_DEPENDENCY_CONTRACT_V1"}}, {"contains": {"const": "D3_DATA_VERSION_QUALITY_MANIFEST_GATE_CONTRACT_V1"}}]},
    "source_status_evidence_fields": {"allOf": [{"$ref": "#/$defs/strings"}, {"contains": {"const": "trading_status"}}, {"contains": {"const": "price_limit_status"}}, {"contains": {"const": "suspension_status"}}, {"contains": {"const": "st_status"}}, {"contains": {"const": "status_resolution_status"}}]},
    "factor_evidence_fields": {"allOf": [{"$ref": "#/$defs/strings"}, {"contains": {"const": "adjustment_factor"}}, {"contains": {"const": "factor_as_of_time"}}, {"contains": {"const": "adjustment_revision"}}, {"contains": {"const": "point_in_time_eligible"}}, {"contains": {"const": "factor_resolution_status"}}]},
    "source_status_resolution_status_enum": {"allOf": [{"$ref": "#/$defs/strings"}, {"contains": {"const": "resolved"}}, {"contains": {"const": "unresolved"}}, {"contains": {"const": "conflicting"}}]},
    "factor_resolution_status_enum": {"allOf": [{"$ref": "#/$defs/strings"}, {"contains": {"const": "resolved"}}, {"contains": {"const": "unresolved"}}, {"contains": {"const": "conflicting"}}]},
    "d2_acceptance_decision_enum": {"allOf": [{"$ref": "#/$defs/strings"}, {"contains": {"const": "accepted_for_d3_candidate_generation"}}, {"contains": {"const": "blocked_pending_source_status_resolution"}}, {"contains": {"const": "blocked_pending_adjustment_factor_resolution"}}, {"contains": {"const": "blocked_pending_point_in_time_evidence"}}, {"contains": {"const": "blocked_pending_quality_resolution"}}, {"contains": {"const": "exploration_only_not_d3_eligible"}}, {"contains": {"const": "rejected"}}]},
    "d3_handoff_decision_enum": {"allOf": [{"$ref": "#/$defs/strings"}, {"contains": {"const": "d3_candidate_generation_allowed"}}, {"contains": {"const": "d3_candidate_generation_blocked"}}, {"contains": {"const": "d3_blocked_gate_report_only_allowed"}}]},
    "forbidden_actions": {"type": "object", "additionalProperties": false, "required": ["default_scan_data_raw", "commit_generated_artifacts", "print_or_log_secrets", "write_duckdb", "create_accepted_manifest", "publish_data_version", "generate_d3_rows", "generate_pcvt_values", "generate_r0_state", "generate_labels_returns_backtests_or_portfolio"], "properties": {"default_scan_data_raw": {"const": false}, "commit_generated_artifacts": {"const": false}, "print_or_log_secrets": {"const": false}, "write_duckdb": {"const": false}, "create_accepted_manifest": {"const": false}, "publish_data_version": {"const": false}, "generate_d3_rows": {"const": false}, "generate_pcvt_values": {"const": false}, "generate_r0_state": {"const": false}, "generate_labels_returns_backtests_or_portfolio": {"const": false}}},
    "active_source_policy": {"type": "object", "additionalProperties": false, "required": ["hithink_primary", "baostock_missing_only_priority", "tushare_missing_only_priority", "a_stock_data_active_allowed", "fallback_silent_override_allowed", "source_conflict_requires_discrepancy_report"], "properties": {"hithink_primary": {"const": true}, "baostock_missing_only_priority": {"const": 1}, "tushare_missing_only_priority": {"const": 2}, "a_stock_data_active_allowed": {"const": false}, "fallback_silent_override_allowed": {"const": false}, "source_conflict_requires_discrepancy_report": {"const": true}}}
  },
  "$defs": {"strings": {"type": "array", "items": {"type": "string"}, "uniqueItems": true, "minItems": 1}}
