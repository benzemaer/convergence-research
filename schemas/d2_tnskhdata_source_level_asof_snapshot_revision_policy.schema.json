{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://benzemaer.local/schemas/d2_tnskhdata_source_level_asof_snapshot_revision_policy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "config_version",
    "policy_id",
    "task_id",
    "source_id",
    "as_of_policy",
    "revision_policy",
    "point_in_time_policy"
  ],
  "properties": {
    "$schema": {"const": "../../schemas/d2_tnskhdata_source_level_asof_snapshot_revision_policy.schema.json"},
    "config_version": {"const": "1.0.0"},
    "policy_id": {"const": "D2_TNSKHDATA_SOURCE_LEVEL_ASOF_SNAPSHOT_REVISION_POLICY_V1"},
    "task_id": {"const": "D2-T12"},
    "source_id": {"const": "tnskhdata"},
    "as_of_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adj_factor_source_level_as_of_time",
        "basis",
        "granularity",
        "row_level_factor_as_of_time_available"
      ],
      "properties": {
        "adj_factor_source_level_as_of_time": {"const": "trade_date 09:20:00 Asia/Shanghai"},
        "basis": {"const": "tnskhdata/Tushare adj_factor documented daily pre-market ingestion window 09:15-09:20"},
        "granularity": {"const": "source_level_policy"},
        "row_level_factor_as_of_time_available": {"const": false}
      }
    },
    "revision_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider_row_level_revision_available",
        "snapshot_level_revision_required",
        "revision_id_source",
        "revision_class"
      ],
      "properties": {
        "provider_row_level_revision_available": {"const": false},
        "snapshot_level_revision_required": {"const": true},
        "revision_id_source": {"const": "source_snapshot_id + artifact_sha256 + run_id"},
        "revision_class": {"const": "snapshot_level_revision"}
      }
    },
    "point_in_time_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligibility_class",
        "eligible_for_eod_research_after_close",
        "eligible_for_strict_provider_row_level_revision"
      ],
      "properties": {
        "eligibility_class": {"const": "source_level_asof_snapshot_revision"},
        "eligible_for_eod_research_after_close": {"const": true},
        "eligible_for_strict_provider_row_level_revision": {"const": false}
      }
    }
  }
}
