{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "R2-T04 input binding",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "phase", "execution_commit", "config_binding", "source_bindings", "source_count", "hash_authority", "compact_t03_only", "local_duckdb_used"],
  "properties": {
    "task_id": {"const": "R2-T04"}, "phase": {"const": "A"}, "execution_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "config_binding": {"type": "object", "required": ["path", "source_commit", "committed_byte_sha256", "git_blob_sha"], "properties": {"path": {"type": "string"}, "source_commit": {"type": "string"}, "committed_byte_sha256": {"type": "string"}, "git_blob_sha": {"type": "string"}}, "additionalProperties": true},
    "source_bindings": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["path", "source_commit", "committed_byte_sha256", "git_blob_sha", "role"], "properties": {"path": {"type": "string"}, "source_commit": {"type": "string"}, "committed_byte_sha256": {"type": "string"}, "git_blob_sha": {"type": "string"}, "role": {"type": "string"}}, "additionalProperties": true}},
    "source_count": {"type": "integer", "minimum": 1}, "hash_authority": {"const": "committed_git_blob_only"}, "compact_t03_only": {"const": true}, "local_duckdb_used": {"const": false}
  }
}
