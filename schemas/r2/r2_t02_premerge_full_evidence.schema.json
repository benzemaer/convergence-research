{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "required": [
        "task_id",
        "repository",
        "pull_request_number",
        "workflow_name",
        "workflow_event",
        "workflow_run_id",
        "workflow_attempt",
        "workflow_conclusion",
        "tested_head_sha",
        "reviewed_head_sha",
        "profile",
        "status",
        "test_count",
        "unique_test_count",
        "test_collection_sha256",
        "independent_full_collection_sha256",
        "runner_test_ids_match_current_full",
        "full_test_ids",
        "failure_count",
        "error_count",
        "skipped_count",
        "elapsed_seconds",
        "heavy_profile",
        "heavy_test_file_set",
        "heavy_test_count",
        "heavy_test_ids",
        "heavy_test_collection_sha256",
        "heavy_subset_of_full",
        "completed_at_utc",
        "formal_surface_sha256",
        "formal_surface_git_blob_sha256",
        "author_package_path",
        "author_package_sha256",
        "committed_artifact_sidecar_path",
        "committed_artifact_sidecar_sha256",
        "author_stage_review_record_path",
        "author_stage_review_record_sha256",
        "scientific_review_record_path",
        "scientific_review_record_sha256"
    ],
    "properties": {
        "task_id": {"const": "R2-T02"},
        "repository": {"type": "string"},
        "pull_request_number": {"type": "integer"},
        "workflow_name": {"type": "string"},
        "workflow_event": {"type": "string"},
        "workflow_run_id": {"type": "integer"},
        "workflow_attempt": {"type": "integer"},
        "workflow_conclusion": {"const": "success"},
        "tested_head_sha": {"type": "string"},
        "reviewed_head_sha": {"type": "string"},
        "profile": {"const": "full"},
        "status": {"const": "passed"},
        "test_count": {"type": "integer"},
        "unique_test_count": {"type": "integer"},
        "test_collection_sha256": {"type": "string"},
        "independent_full_collection_sha256": {"type": "string"},
        "runner_test_ids_match_current_full": {"const": true},
        "full_test_ids": {"type": "array", "items": {"type": "string"}},
        "failure_count": {"const": 0},
        "error_count": {"const": 0},
        "skipped_count": {"type": "integer"},
        "elapsed_seconds": {"type": "number"},
        "heavy_profile": {"const": "r0-heavy-premerge"},
        "heavy_test_file_set": {"type": "array"},
        "heavy_test_count": {"type": "integer"},
        "heavy_test_ids": {"type": "array", "items": {"type": "string"}},
        "heavy_test_collection_sha256": {"type": "string"},
        "heavy_subset_of_full": {"const": true},
        "completed_at_utc": {"type": "string"},
        "formal_surface_sha256": {"type": "string"},
        "formal_surface_git_blob_sha256": {"type": "string"},
        "author_package_path": {"type": "string"},
        "author_package_sha256": {"type": "string"},
        "committed_artifact_sidecar_path": {"type": "string"},
        "committed_artifact_sidecar_sha256": {"type": "string"},
        "author_stage_review_record_path": {"type": "string"},
        "author_stage_review_record_sha256": {"type": "string"},
        "scientific_review_record_path": {"type": "string"},
        "scientific_review_record_sha256": {"type": "string"}
    }
}
