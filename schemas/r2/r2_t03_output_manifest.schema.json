{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "R2-T03 output manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["task_id", "run_id", "execution_commit", "config_sha256", "source_readiness_sha256", "input_binding_sha256", "artifact_count", "artifacts", "large_artifacts", "database_tables", "database_fingerprint", "post_validation_fingerprint", "status"],
  "properties": {
    "task_id": {"const": "R2-T03"},
    "run_id": {"type": "string", "pattern": "^R2-T03-"},
    "execution_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "config_sha256": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "source_readiness_sha256": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "input_binding_sha256": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "artifact_count": {"type": "integer", "minimum": 1},
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 0}
        }
      }
    },
    "large_artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes", "lifecycle", "table_row_counts", "database_fingerprint"],
        "properties": {
          "path": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "size_bytes": {"type": "integer", "minimum": 1},
          "lifecycle": {"const": "local_large_artifact_not_committed"},
          "table_row_counts": {"type":"object","additionalProperties":{"type":"integer","minimum":0}},
          "database_fingerprint": {"type":"object"}
        }
      }
    },
    "database_tables": {"type": "object", "additionalProperties": {"type": "integer", "minimum": 0}},
    "database_fingerprint": {"type":"object"},
    "post_validation_fingerprint": {"type":"object"},
    "status": {"const": "passed"}
  }
}
