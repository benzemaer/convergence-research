{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "R2-T04 Phase B explicit user decision input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "run_id",
    "decision_authority",
    "reviewer_identity",
    "github_identity",
    "decision_time_utc",
    "decision_goal",
    "automatic_recommendation_override",
    "phase_a_review_resolution_path",
    "phase_a_automatic_recommendation_path",
    "decision_units",
    "parameter_search_closed",
    "interaction_sidecar_requested",
    "T25_V30_scan_requested",
    "decision_input_hash"
  ],
  "properties": {
    "task_id": {"const": "R2-T04"},
    "run_id": {"const": "R2-T04-20260713T120000Z"},
    "decision_authority": {"const": "user_explicit_instruction"},
    "reviewer_identity": {"const": "Jianfeng Xie"},
    "github_identity": {"const": "benzemaer"},
    "decision_time_utc": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "decision_goal": {"const": "interpretable_freeze_not_global_parameter_optimum"},
    "automatic_recommendation_override": {"const": true},
    "phase_a_review_resolution_path": {"const": "r2_t04_phase_a_review_resolution.json"},
    "phase_a_automatic_recommendation_path": {"const": "r2_t04_automatic_recommendation.json"},
    "decision_units": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {"$ref": "#/$defs/decision_unit"}
    },
    "parameter_search_closed": {"const": true},
    "interaction_sidecar_requested": {"const": false},
    "T25_V30_scan_requested": {"const": false},
    "decision_input_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "$defs": {
    "decision_unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_unit",
        "automatic_recommendation",
        "user_disposition",
        "primary_disposition",
        "shared_disposition",
        "pair_disposition",
        "selected_candidate_cell_id",
        "selected_d",
        "selected_g",
        "paired_primary_candidate",
        "paired_shared_candidate",
        "strict_core_enabled",
        "primary_reason_code",
        "secondary_reason_codes",
        "accepted_warnings",
        "accepted_event_zone_tradeoffs",
        "rejected_alternatives",
        "automatic_recommendation_authoritative",
        "override",
        "override_justification",
        "decision_time",
        "reviewer_identity",
        "github_identity",
        "decision_authority",
        "evidence_refs",
        "evidence_values"
      ],
      "properties": {
        "decision_unit": {"enum": ["S_PCT×W120", "S_PCT×W250", "S_PCVT×W120", "S_PCVT×W250"]},
        "automatic_recommendation": {"type": ["string", "null"]},
        "user_disposition": {"enum": ["selected", "rejected", "retain_as_strict_core_only", "reject_pair"]},
        "primary_disposition": {"enum": ["selected", "rejected", "retain_as_strict_core_only", "reject_pair"]},
        "shared_disposition": {"enum": ["selected", "rejected", "retain_as_strict_core_only", "reject_pair"]},
        "pair_disposition": {"enum": ["selected", "rejected", "retain_as_strict_core_only", "reject_pair"]},
        "selected_candidate_cell_id": {"type": ["string", "null"]},
        "selected_d": {"type": ["integer", "null"]},
        "selected_g": {"type": ["integer", "null"]},
        "paired_primary_candidate": {"type": "string"},
        "paired_shared_candidate": {"type": "string"},
        "strict_core_enabled": {"type": "boolean"},
        "primary_reason_code": {"type": "string", "minLength": 1},
        "secondary_reason_codes": {"type": "array", "items": {"type": "string"}},
        "accepted_warnings": {"type": "array", "items": {"type": "string"}},
        "accepted_event_zone_tradeoffs": {"type": "array", "items": {"type": "string"}},
        "rejected_alternatives": {"type": "array", "items": {"type": "string"}},
        "automatic_recommendation_authoritative": {"const": false},
        "override": {"const": true},
        "override_justification": {"type": "string", "minLength": 20},
        "decision_time": {"type": "string", "pattern": "^20[0-9]{2}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
        "reviewer_identity": {"const": "Jianfeng Xie"},
        "github_identity": {"const": "benzemaer"},
        "decision_authority": {"const": "user_explicit_instruction"},
        "evidence_refs": {"type": "array", "minItems": 2, "items": {"type": "string"}},
        "evidence_values": {"type": "object"}
      }
    }
  }
}
