{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["task_id", "state_risk_set_rule", "qualified_event_risk_set_rule", "guards", "prohibited_uses", "authoritative_expected_key_binding", "binding_reuse_policy"],
  "properties": {
    "task_id": {"const": "R2-T02"},
    "state_risk_set_rule": {"const": "confirmed_and_available_and_eligible_and_quality_valid"},
    "qualified_event_risk_set_rule": {"const": "state_risk_set_and_component_qualified_as_of"},
    "guards": {"type": "array", "minItems": 9, "uniqueItems": true, "contains": {"const": "qualified_event_risk_true_implies_state_risk_true"}},
    "prohibited_uses": {"type": "array", "minItems": 6, "uniqueItems": true},
    "authoritative_expected_key_binding": {"type": "object", "required": ["path", "sha256", "source_run_id", "schema_version", "primary_key", "date_field", "index_field", "attestation_path", "attestation_sha256"], "properties": {"path": {"type": "string"}, "sha256": {"type": "string"}, "source_run_id": {"type": "string"}, "schema_version": {"type": "string"}, "primary_key": {"type": "array", "minItems": 1, "items": {"type": "string"}}, "date_field": {"type": "string"}, "index_field": {"type": "string"}, "attestation_path": {"type": "string"}, "attestation_sha256": {"type": "string"}}, "additionalProperties": false},
    "binding_reuse_policy": {"const": "R2-T03_must_consume_identical_binding_without_reinterpretation"}
  },
  "additionalProperties": false
}
