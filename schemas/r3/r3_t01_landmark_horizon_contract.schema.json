{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://convergence-research.local/schemas/r3/r3_t01_landmark_horizon_contract.schema.json",
  "title": "R3-T01 landmark and horizon contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract_version", "landmark_ids", "t0_definition", "future_landmark_definition", "horizons", "primary_horizon", "horizon_counting_rule", "deferred_prediction_rule_owner", "t01_scope"],
  "properties": {
    "contract_version": {"const": "r3_t01.v1"},
    "landmark_ids": {"const": ["T0", "T1", "T2"]},
    "t0_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["date", "time", "counts_as_future_ordinal_zero", "time_resolution"],
      "properties": {
        "date": {"const": "exit_attempt_date"},
        "time": {"const": "null_upstream_interface_gap"},
        "counts_as_future_ordinal_zero": {"const": true},
        "time_resolution": {"const": "daily_causal_date_only"}
      }
    },
    "future_landmark_definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["first_valid_row_rule", "group_keys", "invalid_rows_counted_as_landmark", "invalid_rows_retained_for_audit", "intervening_fields", "unobservable_reasons"],
      "properties": {
        "first_valid_row_rule": {"type": "string"},
        "group_keys": {"const": ["state_version_id", "security_id"]},
        "invalid_rows_counted_as_landmark": {"const": false},
        "invalid_rows_retained_for_audit": {"const": true},
        "intervening_fields": {"type": "array", "items": {"type": "string"}},
        "unobservable_reasons": {"type": "array", "items": {"type": "string"}}
      }
    },
    "horizons": {
      "type": "array",
      "const": [
        {"horizon_id": "H5", "valid_trading_row_count": 5, "role": "early reaction"},
        {"horizon_id": "H10", "valid_trading_row_count": 10, "role": "short-term path formation"},
        {"horizon_id": "H20", "valid_trading_row_count": 20, "role": "primary path-classification horizon"},
        {"horizon_id": "H30", "valid_trading_row_count": 30, "role": "extension and late-reversal check"}
      ],
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["horizon_id", "valid_trading_row_count", "role"],
        "properties": {
          "horizon_id": {"enum": ["H5", "H10", "H20", "H30"]},
          "valid_trading_row_count": {"enum": [5, 10, 20, 30]},
          "role": {"type": "string"}
        }
      }
    },
    "primary_horizon": {"const": "H20"},
    "horizon_counting_rule": {"type": "string"},
    "deferred_prediction_rule_owner": {"const": "R4"},
    "t01_scope": {"type": "string"}
  }
}
