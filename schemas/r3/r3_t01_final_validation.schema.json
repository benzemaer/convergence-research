{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://convergence-research.local/schemas/r3/r3_t01_final_validation.schema.json",
  "title": "R3-T01 post-manifest final validation sidecar",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "run_id",
    "status",
    "validated_manifest_sha256",
    "validated_artifact_count",
    "reviewed_implementation_sha",
    "formal_execution_sha",
    "approval_comment_id",
    "validator_status",
    "anomaly_status",
    "result_analysis_status",
    "manifest_binding_status",
    "tamper_check_status",
    "error_count",
    "errors",
    "formal_run_status"
  ],
  "properties": {
    "task_id": {"const": "R3-T01"},
    "run_id": {"type": "string", "minLength": 1},
    "status": {"enum": ["passed", "failed"]},
    "validated_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "validated_artifact_count": {"type": "integer", "minimum": 0},
    "reviewed_implementation_sha": {"type": ["string", "null"]},
    "formal_execution_sha": {"type": ["string", "null"]},
    "approval_comment_id": {"type": ["integer", "null"]},
    "validator_status": {"enum": ["passed", "failed"]},
    "anomaly_status": {"enum": ["passed", "failed"]},
    "result_analysis_status": {"enum": ["passed", "needs_revision", "failed"]},
    "manifest_binding_status": {"enum": ["passed", "failed"]},
    "tamper_check_status": {"enum": ["passed", "failed"]},
    "error_count": {"type": "integer", "minimum": 0},
    "errors": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": {"type": "string", "minLength": 1},
          "message": {"type": "string"}
        }
      }
    },
    "formal_run_status": {"enum": ["completed", "blocked_needs_revision", "failed"]}
  }
}
