{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benzemaer/convergence-research/schemas/r1/r1_t07_p_onset_fixed_lag_relations.schema.json",
  "title": "R1-T07 P onset fixed lag relations contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "stage",
    "protocol_version",
    "task_class",
    "depends_on_task",
    "r1_t06_evidence_path",
    "r1_t06_result_package_path",
    "r1_t06_final_gate_validation_path",
    "r1_t06_scientific_review_path",
    "r0_t11_handoff_evidence_path",
    "r0_t11_handoff_report_path",
    "r0_repair_evidence_path",
    "validation_protocol_manifest_lock_path",
    "input_artifacts",
    "W",
    "q",
    "K",
    "lag_set",
    "weak_delta",
    "dimension_rule",
    "primary_baseline",
    "challengers",
    "bootstrap",
    "parallelism",
    "transition_paths",
    "baselines",
    "expected_parameter_response",
    "forbidden_tokens"
  ],
  "properties": {
    "task_id": {"const": "R1-T07"},
    "stage": {"const": "R1"},
    "protocol_version": {"const": "R1.v0.3.R1-T07.v1"},
    "task_class": {"const": "formal_experiment"},
    "depends_on_task": {"const": "R1-T06"},
    "r1_t06_evidence_path": {"type": "string"},
    "r1_t06_result_package_path": {"type": "string"},
    "r1_t06_final_gate_validation_path": {"type": "string"},
    "r1_t06_scientific_review_path": {"type": "string"},
    "r0_t11_handoff_evidence_path": {"type": "string"},
    "r0_t11_handoff_report_path": {"type": "string"},
    "r0_repair_evidence_path": {"type": "string"},
    "validation_protocol_manifest_lock_path": {"type": "string"},
    "input_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension_state", "nested_daily_state"],
      "properties": {
        "dimension_state": {"$ref": "#/$defs/input_artifact"},
        "nested_daily_state": {"$ref": "#/$defs/input_artifact"}
      }
    },
    "W": {"type": "array", "prefixItems": [{"const": 120}, {"const": 250}, {"const": 500}], "minItems": 3, "maxItems": 3},
    "q": {"type": "array", "prefixItems": [{"const": 0.1}, {"const": 0.2}, {"const": 0.3}], "minItems": 3, "maxItems": 3},
    "K": {"const": "not_applicable"},
    "lag_set": {"type": "array", "prefixItems": [{"const": 1}, {"const": 3}, {"const": 5}, {"const": 10}, {"const": 20}], "minItems": 5, "maxItems": 5},
    "weak_delta": {"const": 0.1},
    "dimension_rule": {"const": "weak"},
    "primary_baseline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["W", "q"],
      "properties": {"W": {"const": 250}, "q": {"const": 0.2}}
    },
    "challengers": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "W", "q"],
        "properties": {
          "id": {"enum": ["short_window", "long_window", "strict_threshold", "loose_threshold"]},
          "W": {"enum": [120, 250, 500]},
          "q": {"enum": [0.1, 0.2, 0.3]}
        }
      }
    },
    "bootstrap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cluster_key", "B_boot", "seed", "interval_method", "lower_percentile", "upper_percentile", "empirical_p", "result_role", "max_failed_replicates"],
      "properties": {
        "cluster_key": {"const": "security_id"},
        "B_boot": {"const": 2000},
        "seed": {"type": "integer"},
        "interval_method": {"const": "percentile"},
        "lower_percentile": {"const": 0.025},
        "upper_percentile": {"const": 0.975},
        "empirical_p": {"type": "null"},
        "result_role": {"const": "secondary_evidence"},
        "max_failed_replicates": {"const": 0}
      }
    },
    "parallelism": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parallelism_mode", "duckdb_threads", "duckdb_memory_limit"],
      "properties": {
        "parallelism_mode": {"const": "duckdb_native_single_process"},
        "duckdb_threads": {"const": 4},
        "duckdb_memory_limit": {"const": "12GB"}
      }
    },
    "transition_paths": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["transition_path", "target_flag", "target_validity"],
        "properties": {
          "transition_path": {"enum": ["P_TO_C", "P_TO_T", "P_TO_V", "P_TO_PCT", "P_TO_PCVT"]},
          "target_flag": {"enum": ["C_raw", "T_raw", "V_raw", "S_PCT_raw", "S_PCVT_raw"]},
          "target_validity": {"enum": ["C_valid", "T_valid", "V_valid", "S_PCT_valid", "S_PCVT_valid"]}
        }
      }
    },
    "baselines": {
      "type": "array",
      "prefixItems": [
        {"const": "stay_out_primary"},
        {"const": "unconditional_lag_support_marginal"},
        {"const": "anchor_target_status_standardized_control"},
        {"const": "security_year_standardized_control"}
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "expected_parameter_response": {"type": "array", "minItems": 6, "items": {"type": "string"}},
    "forbidden_tokens": {"type": "array", "minItems": 15, "items": {"type": "string"}}
  },
  "$defs": {
    "input_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_path", "path", "table", "sha256", "row_count", "security_count", "date_min", "date_max"],
      "properties": {
        "evidence_path": {"type": "string"},
        "path": {"type": "string", "pattern": "R0-T10-03-20260708T1740Z"},
        "table": {"type": "string"},
        "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "row_count": {"type": "integer", "minimum": 1},
        "security_count": {"const": 800},
        "date_min": {"const": "20160104"},
        "date_max": {"const": "20260630"}
      }
    }
  }
}
