{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benzemaer/convergence-research/schemas/d2_acceptance_d3_handoff_blocking_report.schema.json",
  "title": "D2 Acceptance D3 Handoff Blocking Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "config_version",
    "report_id",
    "task_id",
    "contract_id",
    "acceptance_status",
    "real_data_read",
    "external_api_called",
    "raw_data_committed",
    "duckdb_written",
    "formal_ingestion_authorized",
    "d2_raw_price_materialized",
    "d2_adjusted_price_materialized",
    "d2_quality_flags_materialized",
    "d3_generated",
    "r0_generated",
    "pcvt_values_generated",
    "returns_or_labels_generated",
    "blocking_reasons",
    "d2_acceptance_summary",
    "d3_handoff_summary",
    "recommended_next_task"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "config_version": {"const": "1.0.0"},
    "report_id": {"const": "D2_ACCEPTANCE_D3_HANDOFF_BLOCKING_REPORT_V1"},
    "task_id": {"const": "D2-T08"},
    "contract_id": {"const": "D2_ACCEPTANCE_D3_HANDOFF_CONTRACT_V1"},
    "acceptance_status": {"const": "contract_only_blocked_pending_real_d2_materialization"},
    "real_data_read": {"const": false},
    "external_api_called": {"const": false},
    "raw_data_committed": {"const": false},
    "duckdb_written": {"const": false},
    "formal_ingestion_authorized": {"const": false},
    "d2_raw_price_materialized": {"const": false},
    "d2_adjusted_price_materialized": {"const": false},
    "d2_quality_flags_materialized": {"const": false},
    "d3_generated": {"const": false},
    "r0_generated": {"const": false},
    "pcvt_values_generated": {"const": false},
    "returns_or_labels_generated": {"const": false},
    "blocking_reasons": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string"},
      "allOf": [
        {"contains": {"const": "formal_ingestion_not_authorized"}},
        {"contains": {"const": "real_d2_raw_price_layer_not_materialized"}},
        {"contains": {"const": "real_d2_adjusted_price_layer_not_materialized"}},
        {"contains": {"const": "real_d2_quality_flags_not_materialized"}},
        {"contains": {"const": "factor_as_of_time_coverage_not_verified"}},
        {"contains": {"const": "revision_timestamp_coverage_not_verified"}},
        {"contains": {"const": "source_terms_pending_for_formal_ingestion"}},
        {"contains": {"const": "d3_generation_not_authorized_by_this_pr"}},
        {"contains": {"const": "r0_generation_not_authorized_by_this_pr"}}
      ]
    },
    "d2_acceptance_summary": {"type": "object"},
    "d3_handoff_summary": {"type": "object"},
    "recommended_next_task": {"const": "D3-T01_daily_market_observations_contract"}
  }
}
