    "authorized_input_manifest_required": { "const": true },
    "real_data_read_authorized": { "const": true },
    "provider_call_authorized": { "const": false },
    "data_raw_read_authorized": { "const": false },
    "data_external_read_authorized": { "const": false },
    "marketdb_read_authorized": { "const": false },
    "day_file_read_authorized": { "const": false },
