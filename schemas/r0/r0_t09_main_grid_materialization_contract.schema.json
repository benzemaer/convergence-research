        { "contains": { "const": "R0_T07_CONFIRMATION_STREAK_INTERVAL_CONTRACT_V1" } },
        { "contains": { "const": "R0_T08_MAIN_GRID_CANDIDATE_ARTIFACT_CONTRACT_V1" } }
      ]
