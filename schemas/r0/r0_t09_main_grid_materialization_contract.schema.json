      "const": [
        "VolShrink20_60_raw",
        "V1_VolShrink20_60",
        "VolShrink20_60",
        "volume_shrink_20_60"
      ]
    },
    "required_input_manifest_fields": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "input_data_version" } },
        { "contains": { "const": "input_schema_version" } },
        { "contains": { "const": "input_content_hash" } },
        { "contains": { "const": "input_row_counts" } },
        { "contains": { "const": "source_lineage" } },
        { "contains": { "const": "authorized_r0_input" } },
        { "contains": { "const": "code_commit_or_data_build_id" } },
        { "contains": { "const": "input_payload_path" } }
      ]
    },
    "per_config_output_files": { "$ref": "#/$defs/stringArray" },
    "partial_file_required": { "const": true },
    "atomic_rename_required": { "const": true },
    "done_marker_required_fields": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "daily_content_hash" } },
        { "contains": { "const": "interval_content_hash" } },
        { "contains": { "const": "status" } }
      ]
    },
    "failed_marker_required_fields": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "error_type" } },
        { "contains": { "const": "error_message" } },
        { "contains": { "const": "retry_command" } }
      ]
    },
    "global_manifest_required_fields": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "candidate_configs" } },
        { "contains": { "const": "per_config_status" } },
        { "contains": { "const": "lineage_guard" } },
        { "contains": { "const": "forbidden_output_guard" } }
      ]
    },
    "forbidden_outputs": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [
        { "contains": { "const": "future_return" } },
        { "contains": { "const": "future_volatility" } },
        { "contains": { "const": "win_rate" } },
        { "contains": { "const": "pnl" } },
        { "contains": { "const": "backtest" } },
        { "contains": { "const": "portfolio" } },
        { "contains": { "const": "trade_signal" } },
        { "contains": { "const": "audit_report" } },
        { "contains": { "const": "r1_handoff" } }
      ]
    },
    "reason_code_vocabulary": { "$ref": "#/$defs/stringArray" }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    }
  }
}
