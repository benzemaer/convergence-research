    "main_grid_materialization_authorized": { "const": true },
    "audit_report_generation_authorized": { "const": false },
    "r1_handoff_generation_authorized": { "const": false },
    "max_workers_default": { "const": 6 },
    "max_workers_upper_bound": { "const": 6 },
    "resume_authorized": { "const": true },
    "only_config_rerun_authorized": { "const": true },
    "dry_run_authorized": { "const": true },
