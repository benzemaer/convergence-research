  ],
  "properties": {
    "$schema": {
      "const": "../../schemas/r0/r0_t09_main_grid_materialization_contract.schema.json"
    },
    "config_version": { "const": "1.0.0" },
    "contract_id": { "const": "R0_T09_MAIN_GRID_MATERIALIZATION_CONTRACT_V1" },
