{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/benzemaer/convergence-research/schemas/d2_raw_market_prices_materialization_contract.schema.json",
  "title": "D2 Raw Market Prices Materialization Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["config_version", "task_id", "contract_id", "contract_status", "target_table", "data_version", "universe_id", "time_segment_id", "depends_on", "required_fields", "primary_key", "authorization", "candidate_source_boundary", "blocking_conditions", "prohibited_row_fields"],
  "properties": {
    "$schema": {"type": "string"},
    "config_version": {"const": "1.0.0"},
    "task_id": {"const": "D2-T03"},
    "contract_id": {"const": "D2_RAW_MARKET_PRICES_MATERIALIZATION_CONTRACT_V1"},
    "contract_status": {"const": "accepted"},
    "target_table": {"const": "d1.raw_market_prices"},
    "data_version": {"const": "D2_RAW_MARKET_PRICES_BLOCKED_PENDING_SOURCE_AUTHORIZATION_V1"},
    "universe_id": {"const": "CSI800_STATIC_2026_06"},
    "time_segment_id": {"const": "DR001_STATIC_BACKFILL_20160101_20260630"},
    "depends_on": {
      "type": "array",
      "uniqueItems": true,
      "allOf": [
        {"contains": {"const": "D2_RAW_OHLCV_SOURCE_CONTRACT_V1"}},
        {"contains": {"const": "D2_CSI800_STATIC_2026_06_MEMBERSHIP_ALIGNMENT_CONTRACT_V1"}},
        {"contains": {"const": "D2_CSI800_STATIC_2026_06_MEMBERSHIP_ALIGNMENT_V1"}},
        {"contains": {"const": "D0_DATA_PRODUCT_CONTRACTS_V1"}},
        {"contains": {"const": "D0_SOURCE_REGISTRY_V1"}},
        {"contains": {"const": "DR-001"}}
      ],
      "items": {"type": "string"}
    },
    "required_fields": {"$ref": "#/$defs/non_empty_unique_strings"},
    "primary_key": {"$ref": "#/$defs/non_empty_unique_strings"},
    "authorization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["materialization_authorized", "formal_ingestion_authorized", "full_market_collection_authorized", "duckdb_write_authorized", "real_market_data_artifact_authorized", "synthetic_test_only"],
      "properties": {
        "materialization_authorized": {"const": false},
        "formal_ingestion_authorized": {"const": false},
        "full_market_collection_authorized": {"const": false},
        "duckdb_write_authorized": {"const": false},
        "real_market_data_artifact_authorized": {"const": false},
        "synthetic_test_only": {"const": true}
      }
    },
    "candidate_source_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_candidate_source_registry_ids", "candidate_only_source_registry_ids", "prohibited_source_registry_ids", "csindex_membership_only", "a_stock_data_recon_formal_source_allowed", "baostock_adjusted_price_formal_source_allowed"],
      "properties": {
        "allowed_candidate_source_registry_ids": {"type": "array", "items": {"enum": ["HITHINK_FINANCIAL_API", "BAOSTOCK"]}, "minItems": 2, "maxItems": 2, "uniqueItems": true},
        "candidate_only_source_registry_ids": {"type": "array", "items": {"enum": ["HITHINK_FINANCIAL_API", "BAOSTOCK"]}, "minItems": 2, "maxItems": 2, "uniqueItems": true},
        "prohibited_source_registry_ids": {"type": "array", "items": {"enum": ["CSINDEX_OFFICIAL", "A_STOCK_DATA_RECON", "PUBLIC_A_SHARE_ENDPOINTS_REVIEW_BUCKET"]}, "minItems": 3, "uniqueItems": true},
        "csindex_membership_only": {"const": true},
        "a_stock_data_recon_formal_source_allowed": {"const": false},
        "baostock_adjusted_price_formal_source_allowed": {"const": false}
      }
    },
    "blocking_conditions": {"$ref": "#/$defs/non_empty_unique_strings"},
    "prohibited_row_fields": {"$ref": "#/$defs/non_empty_unique_strings"}
  },
  "$defs": {
    "non_empty_unique_strings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
